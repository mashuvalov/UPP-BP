Процедура ВыгрузитьНажатие(Элемент)

    ИмяФайла = ВыбратьФайлВыгрузки();
    Если ПустаяСтрока(ИмяФайла) Тогда
        Возврат;
    КонецЕсли;

    Параметры = Новый Структура;
    Параметры.Вставить("ДатаОстатков", ТекущаяДата());
    Параметры.Вставить("ИмяФайла", ИмяФайла);
    Параметры.Вставить("ВыгружатьНоменклатуру", Истина);
    Параметры.Вставить("ВыгружатьКонтрагентов", Истина);
    Параметры.Вставить("ТолькоПоложительныеОстатки", Истина);

    Протокол = Новый Массив;

    Попытка
        Результат = ВыполнитьВыгрузкуФормы(Параметры, Протокол);
    Исключение
        Предупреждение(ОписаниеОшибки());
        Возврат;
    КонецПопытки;

    Для Каждого ТекстСообщения Из Протокол Цикл
        Сообщить(ТекстСообщения);
    КонецЦикла;

    Сообщить("Выгрузка завершена. Контрагентов: "
        + Строка(Результат.КоличествоКонтрагентов)
        + ", адресов: "
        + Строка(Результат.КоличествоАдресовКонтрагентов)
        + ", счетов: "
        + Строка(Результат.КоличествоБанковскихСчетов)
        + ", контактных лиц: "
        + Строка(Результат.КоличествоКонтактныхЛицКонтрагентов)
        + ", номенклатуры: "
        + Строка(Результат.КоличествоНоменклатуры)
        + ", штрихкодов: "
        + Строка(Результат.КоличествоШтрихкодов));

КонецПроцедуры

Функция ВыбратьФайлВыгрузки()

    Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
    Диалог.ПолноеИмяФайла = КаталогВременныхФайлов() + "КарточкиУПП_в_БП30.xml";
    Диалог.Фильтр = "XML-файлы (*.xml)|*.xml";
    Диалог.Заголовок = "Выберите файл выгрузки";

    Если Диалог.Выбрать() Тогда
        Возврат Диалог.ПолноеИмяФайла;
    КонецЕсли;

    Возврат "";

КонецФункции
Функция ВыполнитьВыгрузкуФормы(Параметры, Протокол = Неопределено)

    Если Протокол = Неопределено Тогда
        Протокол = Новый Массив;
    КонецЕсли;

    ПроверитьПараметрыВыгрузки(Параметры);

    ДатаОстатков = КонецДня(ПолучитьПараметр(Параметры, "ДатаОстатков"));
    ИмяФайла = СокрЛП(ПолучитьПараметр(Параметры, "ИмяФайла"));

    ВыгружатьНоменклатуру = ПолучитьПараметр(Параметры, "ВыгружатьНоменклатуру", Истина);
    ВыгружатьКонтрагентов = ПолучитьПараметр(Параметры, "ВыгружатьКонтрагентов", Истина);
    ТолькоПоложительныеОстатки = ПолучитьПараметр(Параметры, "ТолькоПоложительныеОстатки", Истина);

    ИмяРегистраОстатков = ПолучитьПараметр(Параметры, "ИмяРегистраОстатков", "ТоварыНаСкладах");
    ИмяРесурсаКоличества = ПолучитьПараметр(Параметры, "ИмяРесурсаКоличества", "Количество");
    ИмяРегистраВзаиморасчетов = ПолучитьПараметр(Параметры, "ИмяРегистраВзаиморасчетов", "ВзаиморасчетыСКонтрагентами");
    ИмяРесурсаСуммыДолга = ПолучитьПараметр(Параметры, "ИмяРесурсаСуммыДолга", "СуммаВзаиморасчетов");

    СсылкиНоменклатуры = Новый Соответствие;
    СсылкиКонтрагентов = Новый Соответствие;
    ДанныеАдресовКонтрагентов = Новый Массив;
    ДанныеБанковскихСчетов = Новый Массив;
    ДанныеКонтактныхЛицКонтрагентов = Новый Массив;
    ДанныеШтрихкодовНоменклатуры = Новый Массив;

    Если ВыгружатьНоменклатуру Тогда
        ДобавитьВПротокол(Протокол, "Отбираю номенклатуру по остаткам...");
        ИсходныеСсылкиНоменклатуры = ПолучитьСсылкиИзРегистров(
            ИмяРегистраОстатков,
            "Номенклатура",
            ИмяРесурсаКоличества,
            ДатаОстатков,
            ?(ТолькоПоложительныеОстатки, "> 0", "<> 0"));
        ДобавитьСсылкиСРодителями(СсылкиНоменклатуры, ИсходныеСсылкиНоменклатуры);
        ДобавитьВПротокол(Протокол, "Номенклатура к выгрузке: " + Строка(СсылкиНоменклатуры.Количество()));

        ДобавитьВПротокол(Протокол, "Собираю штрихкоды номенклатуры...");
        ДанныеШтрихкодовНоменклатуры = СобратьДанныеШтрихкодовНоменклатуры(СсылкиНоменклатуры);
        ДобавитьВПротокол(Протокол, "Штрихкодов к выгрузке: " + Строка(ДанныеШтрихкодовНоменклатуры.Количество()));
    КонецЕсли;

    Если ВыгружатьКонтрагентов Тогда
        ДобавитьВПротокол(Протокол, "Отбираю контрагентов с задолженностью...");
        ИсходныеСсылкиКонтрагентов = ПолучитьСсылкиИзРегистров(
            ИмяРегистраВзаиморасчетов,
            "Контрагент",
            ИмяРесурсаСуммыДолга,
            ДатаОстатков,
            "<> 0");
        ДобавитьСсылкиСРодителями(СсылкиКонтрагентов, ИсходныеСсылкиКонтрагентов);
        ДобавитьВПротокол(Протокол, "Контрагенты к выгрузке: " + Строка(СсылкиКонтрагентов.Количество()));

        ДобавитьВПротокол(Протокол, "Собираю адреса контрагентов...");
        ДанныеАдресовКонтрагентов = СобратьДанныеАдресовКонтрагентов(СсылкиКонтрагентов);
        ДобавитьВПротокол(Протокол, "Адресов к выгрузке: " + Строка(ДанныеАдресовКонтрагентов.Количество()));

        ДобавитьВПротокол(Протокол, "Собираю банковские счета контрагентов...");
        ДанныеБанковскихСчетов = СобратьДанныеБанковскихСчетов(СсылкиКонтрагентов);
        ДобавитьВПротокол(Протокол, "Банковских счетов к выгрузке: " + Строка(ДанныеБанковскихСчетов.Количество()));

        ДобавитьВПротокол(Протокол, "Собираю контактных лиц контрагентов...");
        ДанныеКонтактныхЛицКонтрагентов = СобратьДанныеКонтактныхЛицКонтрагентов(СсылкиКонтрагентов);
        ДобавитьВПротокол(Протокол, "Контактных лиц к выгрузке: " + Строка(ДанныеКонтактныхЛицКонтрагентов.Количество()));
    КонецЕсли;

    ЗаписатьПакетОбменаВФайл(
        ИмяФайла,
        ДатаОстатков,
        СсылкиКонтрагентов,
        ДанныеАдресовКонтрагентов,
        ДанныеБанковскихСчетов,
        ДанныеКонтактныхЛицКонтрагентов,
        СсылкиНоменклатуры,
        ДанныеШтрихкодовНоменклатуры,
        Протокол);

    Результат = Новый Структура;
    Результат.Вставить("ИмяФайла", ИмяФайла);
    Результат.Вставить("КоличествоКонтрагентов", СсылкиКонтрагентов.Количество());
    Результат.Вставить("КоличествоАдресовКонтрагентов", ДанныеАдресовКонтрагентов.Количество());
    Результат.Вставить("КоличествоБанковскихСчетов", ДанныеБанковскихСчетов.Количество());
    Результат.Вставить("КоличествоКонтактныхЛицКонтрагентов", ДанныеКонтактныхЛицКонтрагентов.Количество());
    Результат.Вставить("КоличествоНоменклатуры", СсылкиНоменклатуры.Количество());
    Результат.Вставить("КоличествоШтрихкодов", ДанныеШтрихкодовНоменклатуры.Количество());
    Возврат Результат;

КонецФункции

Процедура ПроверитьПараметрыВыгрузки(Параметры)

    Если Параметры = Неопределено Тогда
        ВызватьИсключение "Не переданы параметры выгрузки.";
    КонецЕсли;

    Если Не ЗначениеЗаполнено(ПолучитьПараметр(Параметры, "ДатаОстатков")) Тогда
        ВызватьИсключение "Не заполнена дата отбора остатков и задолженности.";
    КонецЕсли;

    Если ПустаяСтрока(СокрЛП(ПолучитьПараметр(Параметры, "ИмяФайла", ""))) Тогда
        ВызватьИсключение "Не заполнено имя файла выгрузки.";
    КонецЕсли;

    Если Не ПолучитьПараметр(Параметры, "ВыгружатьНоменклатуру", Истина)
       И Не ПолучитьПараметр(Параметры, "ВыгружатьКонтрагентов", Истина) Тогда
        ВызватьИсключение "Нужно выбрать хотя бы один вид данных для выгрузки.";
    КонецЕсли;

КонецПроцедуры

Функция ПолучитьСсылкиИзРегистров(ИмяИлиСписокРегистров, ИмяПоляСсылки, ИмяРесурса, ДатаОстатков, УсловиеПоОстатку)

    СсылкиСоответствие = Новый Соответствие;

    Для Каждого ИмяРегистра Из ПолучитьСписокИмен(ИмяИлиСписокРегистров) Цикл
        Для Каждого Ссылка Из ПолучитьСсылкиИзРегистра(ИмяРегистра, ИмяПоляСсылки, ИмяРесурса, ДатаОстатков, УсловиеПоОстатку) Цикл
            Если Не СоответствиеСодержитКлюч(СсылкиСоответствие, Ссылка) Тогда
                СсылкиСоответствие.Вставить(Ссылка, Истина);
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;

    Результат = Новый Массив;
    Для Каждого Пара Из СсылкиСоответствие Цикл
        Результат.Добавить(Пара.Ключ);
    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция ПолучитьСсылкиИзРегистра(ИмяРегистра, ИмяПоляСсылки, ИмяРесурса, ДатаОстатков, УсловиеПоОстатку)

    ТекстЗапроса =
    "ВЫБРАТЬ
    |   Остатки." + ИмяПоляСсылки + " КАК Ссылка
    |ИЗ
    |   РегистрНакопления." + ИмяРегистра + ".Остатки(&ДатаОстатков, ) КАК Остатки
    |ГДЕ
    |   НЕ Остатки." + ИмяПоляСсылки + ".ПометкаУдаления
    |СГРУППИРОВАТЬ ПО
    |   Остатки." + ИмяПоляСсылки + "
    |ИМЕЮЩИЕ
    |   СУММА(Остатки." + ИмяРесурса + "Остаток) " + УсловиеПоОстатку;

    Запрос = Новый Запрос(ТекстЗапроса);
    Запрос.УстановитьПараметр("ДатаОстатков", ДатаОстатков);

    Попытка
        Выборка = Запрос.Выполнить().Выбрать();
    Исключение
        ВызватьИсключение "Не удалось выполнить отбор по регистру " + ИмяРегистра
            + ". Проверьте имя регистра и имя ресурса " + ИмяРесурса + ". "
            + ОписаниеОшибки();
    КонецПопытки;
    Ссылки = Новый Массив;

    Пока Выборка.Следующий() Цикл
        Если ЗначениеЗаполнено(Выборка.Ссылка) Тогда
            Ссылки.Добавить(Выборка.Ссылка);
        КонецЕсли;
    КонецЦикла;

    Возврат Ссылки;

КонецФункции

Функция ПолучитьСписокИмен(СтрокаИмен)

    ПодготовленнаяСтрока = СокрЛП(Строка(СтрокаИмен));
    ПодготовленнаяСтрока = СтрЗаменить(ПодготовленнаяСтрока, Символы.ПС, ";");
    ПодготовленнаяСтрока = СтрЗаменить(ПодготовленнаяСтрока, ",", ";");

    Части = СтрРазделить(ПодготовленнаяСтрока, ";");
    Результат = Новый Массив;

    Для Каждого Часть Из Части Цикл
        Имя = СокрЛП(Часть);
        Если Не ПустаяСтрока(Имя) Тогда
            Результат.Добавить(Имя);
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;

КонецФункции

Процедура ДобавитьСсылкиСРодителями(СсылкиНазначения, СсылкиИсточник)

    Для Каждого Ссылка Из СсылкиИсточник Цикл
        ТекущаяСсылка = Ссылка;
        Пока ЗначениеЗаполнено(ТекущаяСсылка) Цикл
            Если Не СоответствиеСодержитКлюч(СсылкиНазначения, ТекущаяСсылка) Тогда
                СсылкиНазначения.Вставить(ТекущаяСсылка, Истина);
            КонецЕсли;
            ТекущаяСсылка = ПолучитьРодителяСсылки(ТекущаяСсылка);
        КонецЦикла;
    КонецЦикла;

КонецПроцедуры

Функция ПолучитьРодителяСсылки(Ссылка)

    Попытка
        Возврат Ссылка.Родитель;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

Функция СобратьДанныеАдресовКонтрагентов(СоответствиеСсылокКонтрагентов)

    Контрагенты = ПодготовитьСписокЭлементов(СоответствиеСсылокКонтрагентов);
    Если Контрагенты.Количество() = 0 Тогда
        Возврат Новый Массив;
    КонецЕсли;

    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   КонтактнаяИнформация.Объект КАК Объект,
        |   КонтактнаяИнформация.Тип КАК Тип,
        |   КонтактнаяИнформация.Вид КАК Вид,
        |   КонтактнаяИнформация.Представление КАК Представление,
        |   КонтактнаяИнформация.Поле1 КАК Поле1,
        |   КонтактнаяИнформация.Поле2 КАК Поле2,
        |   КонтактнаяИнформация.Поле3 КАК Поле3,
        |   КонтактнаяИнформация.Поле4 КАК Поле4,
        |   КонтактнаяИнформация.Поле5 КАК Поле5,
        |   КонтактнаяИнформация.Поле6 КАК Поле6,
        |   КонтактнаяИнформация.Поле7 КАК Поле7,
        |   КонтактнаяИнформация.Поле8 КАК Поле8,
        |   КонтактнаяИнформация.Поле9 КАК Поле9,
        |   КонтактнаяИнформация.Поле10 КАК Поле10
        |ИЗ
        |   РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
        |ГДЕ
        |   КонтактнаяИнформация.Объект В (&Контрагенты)");
    Запрос.УстановитьПараметр("Контрагенты", Контрагенты);

    Результат = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Если Не ЭтоАдреснаяКонтактнаяИнформация(Выборка.Тип) Тогда
            Продолжить;
        КонецЕсли;

        Данные = Новый Структура;
        Данные.Вставить("КодКонтрагента", ПолучитьКодСсылки(Выборка.Объект));
        Данные.Вставить("Тип", Строка(Выборка.Тип));
        Данные.Вставить("Вид", Строка(Выборка.Вид));
        Данные.Вставить("Представление", СокрЛП(Строка(Выборка.Представление)));
        Данные.Вставить("Поле1", СокрЛП(Строка(Выборка.Поле1)));
        Данные.Вставить("Поле2", СокрЛП(Строка(Выборка.Поле2)));
        Данные.Вставить("Поле3", СокрЛП(Строка(Выборка.Поле3)));
        Данные.Вставить("Поле4", СокрЛП(Строка(Выборка.Поле4)));
        Данные.Вставить("Поле5", СокрЛП(Строка(Выборка.Поле5)));
        Данные.Вставить("Поле6", СокрЛП(Строка(Выборка.Поле6)));
        Данные.Вставить("Поле7", СокрЛП(Строка(Выборка.Поле7)));
        Данные.Вставить("Поле8", СокрЛП(Строка(Выборка.Поле8)));
        Данные.Вставить("Поле9", СокрЛП(Строка(Выборка.Поле9)));
        Данные.Вставить("Поле10", СокрЛП(Строка(Выборка.Поле10)));
        Результат.Добавить(Данные);
    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция СобратьДанныеБанковскихСчетов(СоответствиеСсылокКонтрагентов)

    Контрагенты = ПодготовитьСписокЭлементов(СоответствиеСсылокКонтрагентов);
    Если Контрагенты.Количество() = 0 Тогда
        Возврат Новый Массив;
    КонецЕсли;

    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   БанковскиеСчета.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.БанковскиеСчета КАК БанковскиеСчета
        |ГДЕ
        |   БанковскиеСчета.Владелец В (&Контрагенты)
        |УПОРЯДОЧИТЬ ПО
        |   БанковскиеСчета.Владелец,
        |   БанковскиеСчета.НомерСчета");
    Запрос.УстановитьПараметр("Контрагенты", Контрагенты);

    Результат = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Если ЗначениеЗаполнено(Выборка.Ссылка) Тогда
            Результат.Добавить(ПодготовитьДанныеБанковскогоСчета(Выборка.Ссылка));
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция СобратьДанныеКонтактныхЛицКонтрагентов(СоответствиеСсылокКонтрагентов)

    Контрагенты = ПодготовитьСписокЭлементов(СоответствиеСсылокКонтрагентов);
    Если Контрагенты.Количество() = 0 Тогда
        Возврат Новый Массив;
    КонецЕсли;

    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   КонтактныеЛицаКонтрагентов.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.КонтактныеЛицаКонтрагентов КАК КонтактныеЛицаКонтрагентов
        |ГДЕ
        |   КонтактныеЛицаКонтрагентов.Владелец В (&Контрагенты)
        |УПОРЯДОЧИТЬ ПО
        |   КонтактныеЛицаКонтрагентов.Владелец,
        |   КонтактныеЛицаКонтрагентов.Наименование");
    Запрос.УстановитьПараметр("Контрагенты", Контрагенты);

    Результат = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Если ЗначениеЗаполнено(Выборка.Ссылка) Тогда
            Результат.Добавить(ПодготовитьДанныеКонтактногоЛицаКонтрагента(Выборка.Ссылка));
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция ПодготовитьДанныеБанковскогоСчета(СсылкаБанковскогоСчета)

