КонецФункции

Функция ПодготовитьДанныеКонтактногоЛицаКонтрагента(СсылкаКонтактногоЛицаКонтрагента)

    Объект = СсылкаКонтактногоЛицаКонтрагента.ПолучитьОбъект();
    Владелец = ПолучитьСвойствоОбъекта(Объект, "Владелец", Неопределено);
    КонтактноеЛицо = ПолучитьСвойствоОбъекта(Объект, "КонтактноеЛицо", Неопределено);
    РольКонтактногоЛица = ПолучитьСвойствоОбъекта(Объект, "РольКонтактногоЛица", Неопределено);
    ОсновноеКонтактноеЛицо = ?(ЗначениеЗаполнено(Владелец), ПолучитьСвойствоОбъекта(Владелец, "ОсновноеКонтактноеЛицо", Неопределено), Неопределено);

    Наименование = ПолучитьПервуюНепустуюСтроку(
        ПолучитьСвойствоОбъекта(КонтактноеЛицо, "Наименование", ""),
        ПолучитьСвойствоОбъекта(Объект, "Наименование", ""));

    Данные = Новый Структура;
    Данные.Вставить("КодКонтрагента", ?(ЗначениеЗаполнено(Владелец), ПолучитьКодСсылки(Владелец), ""));
    Данные.Вставить("Код", ПолучитьКодСсылки(СсылкаКонтактногоЛицаКонтрагента));
    Данные.Вставить("Наименование", Наименование);
    Данные.Вставить("Фамилия", ПолучитьСвойствоОбъекта(КонтактноеЛицо, "Фамилия", ""));
    Данные.Вставить("Имя", ПолучитьСвойствоОбъекта(КонтактноеЛицо, "Имя", ""));
    Данные.Вставить("Отчество", ПолучитьСвойствоОбъекта(КонтактноеЛицо, "Отчество", ""));
    Данные.Вставить("ДатаРождения", ПолучитьСвойствоОбъекта(КонтактноеЛицо, "ДатаРождения", Неопределено));
    Данные.Вставить("Должность", ПолучитьСвойствоОбъекта(Объект, "Должность", ""));
    Данные.Вставить("Комментарий", ПолучитьСвойствоОбъекта(Объект, "Комментарий", ""));
    Данные.Вставить("Описание", ПолучитьСвойствоОбъекта(КонтактноеЛицо, "Описание", ""));
    Данные.Вставить("Роль", ?(ЗначениеЗаполнено(РольКонтактногоЛица), ПолучитьСвойствоОбъекта(РольКонтактногоЛица, "Наименование", ""), ""));
    Данные.Вставить("Основное", БулевоВСтроку(СсылкаКонтактногоЛицаКонтрагента = ОсновноеКонтактноеЛицо));

    Возврат Данные;

КонецФункции

Функция СобратьДанныеШтрихкодовНоменклатуры(СоответствиеСсылокНоменклатуры)

    Номенклатура = ПодготовитьСписокЭлементов(СоответствиеСсылокНоменклатуры);
    Если Номенклатура.Количество() = 0 Тогда
        Возврат Новый Массив;
    КонецЕсли;

    Запрос = Новый Запрос(
        "ВЫБРАТЬ РАЗЛИЧНЫЕ
        |   Штрихкоды.Владелец КАК Владелец,
        |   Штрихкоды.Штрихкод КАК Штрихкод,
        |   Штрихкоды.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
        |   Штрихкоды.СерияНоменклатуры КАК СерияНоменклатуры
        |ИЗ
        |   РегистрСведений.Штрихкоды КАК Штрихкоды
        |ГДЕ
        |   Штрихкоды.Владелец В (&Номенклатура)
        |УПОРЯДОЧИТЬ ПО
        |   Штрихкоды.Владелец,
        |   Штрихкоды.Штрихкод");
    Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

    Результат = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Если ЗначениеЗаполнено(Выборка.ХарактеристикаНоменклатуры)
           Или ЗначениеЗаполнено(Выборка.СерияНоменклатуры) Тогда
            Продолжить;
        КонецЕсли;

        Штрихкод = СокрЛП(Строка(Выборка.Штрихкод));
        Если ПустаяСтрока(Штрихкод) Тогда
            Продолжить;
        КонецЕсли;

        Данные = Новый Структура;
        Данные.Вставить("КодНоменклатуры", ПолучитьКодСсылки(Выборка.Владелец));
        Данные.Вставить("Штрихкод", Штрихкод);
        Результат.Добавить(Данные);
    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция ПодготовитьСписокЭлементов(СоответствиеСсылок)

    Результат = Новый Массив;
    Для Каждого Пара Из СоответствиеСсылок Цикл
        Если ЗначениеЗаполнено(Пара.Ключ) И Не ЭтоГруппаСсылки(Пара.Ключ) Тогда
            Результат.Добавить(Пара.Ключ);
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция ЭтоАдреснаяКонтактнаяИнформация(ТипКонтактнойИнформации)

    Попытка
        Возврат ТипКонтактнойИнформации = Перечисления.ТипыКонтактнойИнформации.Адрес;
    Исключение
    КонецПопытки;

    Возврат НРег(СокрЛП(Строка(ТипКонтактнойИнформации))) = "адрес";

КонецФункции

Процедура ЗаписатьПакетОбменаВФайл(
    ИмяФайла,
    ДатаОстатков,
    СсылкиКонтрагентов,
    ДанныеАдресовКонтрагентов,
    ДанныеБанковскихСчетов,
    ДанныеКонтактныхЛицКонтрагентов,
    СсылкиНоменклатуры,
    ДанныеШтрихкодовНоменклатуры,
    Протокол)

    Запись = Новый ЗаписьXML;
    Запись.ОткрытьФайл(ИмяФайла);
    Запись.ЗаписатьОбъявлениеXML();

    Запись.ЗаписатьНачалоЭлемента("ПакетОбменаКарточками");
    ЗаписатьПростойЭлементXML(Запись, "ВерсияФормата", "1.1");
    ЗаписатьПростойЭлементXML(Запись, "ДатаВыгрузки", Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy HH:mm:ss"));
    ЗаписатьПростойЭлементXML(Запись, "ДатаОстатков", Формат(ДатаОстатков, "ДФ=dd.MM.yyyy HH:mm:ss"));
    ЗаписатьПростойЭлементXML(Запись, "КонфигурацияИсточник", Метаданные.Синоним);

    Запись.ЗаписатьНачалоЭлемента("Контрагенты");
    Для Каждого СсылкаКонтрагента Из ПодготовитьСсылкиКВыгрузке(СсылкиКонтрагентов) Цикл
        ЗаписатьСтруктуруXML(Запись, "Контрагент", ПодготовитьДанныеКонтрагента(СсылкаКонтрагента));
    КонецЦикла;
    Запись.ЗаписатьКонецЭлемента();

    Запись.ЗаписатьНачалоЭлемента("АдресаКонтрагентов");
    Для Каждого ДанныеАдреса Из ДанныеАдресовКонтрагентов Цикл
        ЗаписатьСтруктуруXML(Запись, "АдресКонтрагента", ДанныеАдреса);
    КонецЦикла;
    Запись.ЗаписатьКонецЭлемента();

    Запись.ЗаписатьНачалоЭлемента("БанковскиеСчетаКонтрагентов");
    Для Каждого ДанныеБанковскогоСчета Из ДанныеБанковскихСчетов Цикл
        ЗаписатьСтруктуруXML(Запись, "БанковскийСчет", ДанныеБанковскогоСчета);
    КонецЦикла;
    Запись.ЗаписатьКонецЭлемента();

    Запись.ЗаписатьНачалоЭлемента("КонтактныеЛицаКонтрагентов");
    Для Каждого ДанныеКонтактногоЛица Из ДанныеКонтактныхЛицКонтрагентов Цикл
        ЗаписатьСтруктуруXML(Запись, "КонтактноеЛицоКонтрагента", ДанныеКонтактногоЛица);
    КонецЦикла;
    Запись.ЗаписатьКонецЭлемента();

    Запись.ЗаписатьНачалоЭлемента("ПозицииНоменклатуры");
    Для Каждого СсылкаНоменклатуры Из ПодготовитьСсылкиКВыгрузке(СсылкиНоменклатуры) Цикл
        ЗаписатьСтруктуруXML(Запись, "Номенклатура", ПодготовитьДанныеНоменклатуры(СсылкаНоменклатуры));
    КонецЦикла;
    Запись.ЗаписатьКонецЭлемента();

    Запись.ЗаписатьНачалоЭлемента("ШтрихкодыНоменклатуры");
    Для Каждого ДанныеШтрихкода Из ДанныеШтрихкодовНоменклатуры Цикл
        ЗаписатьСтруктуруXML(Запись, "ШтрихкодНоменклатуры", ДанныеШтрихкода);
    КонецЦикла;
    Запись.ЗаписатьКонецЭлемента();

    Запись.ЗаписатьКонецЭлемента();
    Запись.Закрыть();

    ДобавитьВПротокол(Протокол, "Файл выгрузки сформирован: " + ИмяФайла);

КонецПроцедуры

Функция ПодготовитьСсылкиКВыгрузке(СоответствиеСсылок)

    ТаблицаСсылок = Новый ТаблицаЗначений;
    ТаблицаСсылок.Колонки.Добавить("Ссылка");
    ТаблицаСсылок.Колонки.Добавить("ЭтоГруппа", Новый ОписаниеТипов("Булево"));
    ТаблицаСсылок.Колонки.Добавить("Уровень", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 0)));
    ТаблицаСсылок.Колонки.Добавить("Представление");

    Для Каждого Пара Из СоответствиеСсылок Цикл
        НоваяСтрока = ТаблицаСсылок.Добавить();
        НоваяСтрока.Ссылка = Пара.Ключ;
        НоваяСтрока.ЭтоГруппа = ЭтоГруппаСсылки(Пара.Ключ);
        НоваяСтрока.Уровень = ПолучитьУровеньИерархии(Пара.Ключ);
        НоваяСтрока.Представление = Строка(Пара.Ключ);
    КонецЦикла;

    ТаблицаСсылок.Сортировать("ЭтоГруппа Убыв, Уровень, Представление");

    Результат = Новый Массив;
    Для Каждого СтрокаТаблицы Из ТаблицаСсылок Цикл
        Результат.Добавить(СтрокаТаблицы.Ссылка);
    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция ПолучитьУровеньИерархии(Ссылка)

    Уровень = 0;
    ТекущаяСсылка = ПолучитьРодителяСсылки(Ссылка);

    Пока ЗначениеЗаполнено(ТекущаяСсылка) Цикл
        Уровень = Уровень + 1;
        ТекущаяСсылка = ПолучитьРодителяСсылки(ТекущаяСсылка);
    КонецЦикла;

    Возврат Уровень;

КонецФункции

Функция ПодготовитьДанныеКонтрагента(СсылкаКонтрагента)

    Объект = СсылкаКонтрагента.ПолучитьОбъект();
    Родитель = ПолучитьРодителяСсылки(СсылкаКонтрагента);
    ИменаПолногоНаименования = Новый Массив;
    ИменаПолногоНаименования.Добавить("ПолноеНаименование");
    ИменаПолногоНаименования.Добавить("НаименованиеПолное");
    ИменаВидаКонтрагента = Новый Массив;
    ИменаВидаКонтрагента.Добавить("ЮрФизЛицо");
    ИменаВидаКонтрагента.Добавить("ВидКонтрагента");

    Данные = Новый Структура;
    Данные.Вставить("Код", ПолучитьСвойствоОбъекта(Объект, "Код", ""));
    Данные.Вставить("Наименование", ПолучитьСвойствоОбъекта(Объект, "Наименование", ""));
    Данные.Вставить("ПолноеНаименование", ПолучитьПервоеСвойство(Объект, ИменаПолногоНаименования));
    Данные.Вставить("ЭтоГруппа", БулевоВСтроку(ЗначениеВБулево(ПолучитьСвойствоОбъекта(Объект, "ЭтоГруппа", Ложь), Ложь)));
    Данные.Вставить("КодРодителя", ?(ЗначениеЗаполнено(Родитель), ПолучитьКодСсылки(Родитель), ""));
    Данные.Вставить("ИНН", ПолучитьСвойствоОбъекта(Объект, "ИНН", ""));
    Данные.Вставить("КПП", ПолучитьСвойствоОбъекта(Объект, "КПП", ""));
    Данные.Вставить("Комментарий", ПолучитьСвойствоОбъекта(Объект, "Комментарий", ""));
    Данные.Вставить("ЮрФизЛицо", Строка(ПолучитьПервоеСвойство(Объект, ИменаВидаКонтрагента)));

    Возврат Данные;

КонецФункции

Функция ПодготовитьДанныеНоменклатуры(СсылкаНоменклатуры)

    Объект = СсылкаНоменклатуры.ПолучитьОбъект();
    Родитель = ПолучитьРодителяСсылки(СсылкаНоменклатуры);
    ИменаЕдиницы = Новый Массив;
    ИменаЕдиницы.Добавить("ЕдиницаХраненияОстатков");
    ИменаЕдиницы.Добавить("БазоваяЕдиницаИзмерения");
    ИменаЕдиницы.Добавить("ЕдиницаИзмерения");
    ИменаПолногоНаименования = Новый Массив;
    ИменаПолногоНаименования.Добавить("ПолноеНаименование");
    ИменаПолногоНаименования.Добавить("НаименованиеПолное");
    ИменаСтавкиНДС = Новый Массив;
    ИменаСтавкиНДС.Добавить("СтавкаНДС");
    ИменаСтавкиНДС.Добавить("СтавкаНалогаНДС");
    ИменаНаименованияЕдиницы = Новый Массив;
    ИменаНаименованияЕдиницы.Добавить("НаименованиеПолное");
    ИменаНаименованияЕдиницы.Добавить("Наименование");
    ИменаКраткогоНаименованияЕдиницы = Новый Массив;
    ИменаКраткогоНаименованияЕдиницы.Добавить("Наименование");
    ИменаКраткогоНаименованияЕдиницы.Добавить("НаименованиеПолное");
    Единица = ПолучитьПервоеСвойство(Объект, ИменаЕдиницы);
    ЭтоУслуга = ЗначениеВБулево(ПолучитьСвойствоОбъекта(Объект, "Услуга", Ложь), Ложь);

    Данные = Новый Структура;
    Данные.Вставить("Код", ПолучитьСвойствоОбъекта(Объект, "Код", ""));
    Данные.Вставить("Наименование", ПолучитьСвойствоОбъекта(Объект, "Наименование", ""));
    Данные.Вставить("ПолноеНаименование", ПолучитьПервоеСвойство(Объект, ИменаПолногоНаименования));
    Данные.Вставить("ЭтоГруппа", БулевоВСтроку(ЗначениеВБулево(ПолучитьСвойствоОбъекта(Объект, "ЭтоГруппа", Ложь), Ложь)));
    Данные.Вставить("КодРодителя", ?(ЗначениеЗаполнено(Родитель), ПолучитьКодСсылки(Родитель), ""));
    Данные.Вставить("Артикул", ПолучитьСвойствоОбъекта(Объект, "Артикул", ""));
    Данные.Вставить("Комментарий", ПолучитьСвойствоОбъекта(Объект, "Комментарий", ""));
    Данные.Вставить("СтавкаНДС", Строка(ПолучитьПервоеСвойство(Объект, ИменаСтавкиНДС)));
    Данные.Вставить("ВидНоменклатуры", ПолучитьВидНоменклатурыПоОбъекту(Объект));
    Данные.Вставить("Услуга", БулевоВСтроку(ЭтоУслуга));
    Данные.Вставить("ЕдиницаИзмеренияКод", ?(ЗначениеЗаполнено(Единица), ПолучитьСвойствоОбъекта(Единица, "Код", ""), ""));
    Данные.Вставить("ЕдиницаИзмерения", ?(ЗначениеЗаполнено(Единица), ПолучитьПервоеСвойство(Единица, ИменаКраткогоНаименованияЕдиницы), ""));
    Данные.Вставить("ЕдиницаИзмеренияПолноеНаименование", ?(ЗначениеЗаполнено(Единица), ПолучитьПервоеСвойство(Единица, ИменаНаименованияЕдиницы), ""));

    Возврат Данные;

КонецФункции

Функция ПолучитьВидНоменклатурыПоОбъекту(Объект)

    ИменаВидаНоменклатуры = Новый Массив;
    ИменаВидаНоменклатуры.Добавить("ВидНоменклатуры");
    ИменаВидаНоменклатуры.Добавить("ТипНоменклатуры");
    ВидНоменклатуры = ПолучитьПервоеСвойство(Объект, ИменаВидаНоменклатуры);
    Если ЗначениеЗаполнено(ВидНоменклатуры) Тогда
        Возврат Строка(ВидНоменклатуры);
    КонецЕсли;

    Если ЗначениеВБулево(ПолучитьСвойствоОбъекта(Объект, "Услуга", Ложь), Ложь) Тогда
        Возврат "Услуга";
    КонецЕсли;

    Возврат "Товар";

КонецФункции

Функция ЭтоГруппаСсылки(Ссылка)

    Попытка
        Возврат Ссылка.ЭтоГруппа;
    Исключение
    КонецПопытки;

    Попытка
        Возврат Ссылка.ПолучитьОбъект().ЭтоГруппа;
    Исключение
    КонецПопытки;

    Возврат Ложь;

КонецФункции

Функция ПолучитьКодСсылки(Ссылка)

    Возврат ПолучитьСвойствоОбъекта(Ссылка, "Код", "");

КонецФункции

Функция ПолучитьСвойствоОбъекта(Объект, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)

    Значение = ЗначениеПоУмолчанию;

    Если Объект = Неопределено Тогда
        Возврат ЗначениеПоУмолчанию;
    КонецЕсли;

    Попытка
        ПриемникСвойства = Новый Структура;
        ПриемникСвойства.Вставить(ИмяСвойства, ЗначениеПоУмолчанию);
        ЗаполнитьЗначенияСвойств(ПриемникСвойства, Объект);
        Если ПриемникСвойства.Свойство(ИмяСвойства, Значение) Тогда
            Возврат Значение;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        ОбъектСвойств = Объект.ПолучитьОбъект();
        ПриемникСвойства = Новый Структура;
        ПриемникСвойства.Вставить(ИмяСвойства, ЗначениеПоУмолчанию);
        ЗаполнитьЗначенияСвойств(ПриемникСвойства, ОбъектСвойств);
        Если ПриемникСвойства.Свойство(ИмяСвойства, Значение) Тогда
            Возврат Значение;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Возврат Вычислить("Объект." + ИмяСвойства);
    Исключение
    КонецПопытки;

    Попытка
        ОбъектСвойств = Объект.ПолучитьОбъект();
        Возврат Вычислить("ОбъектСвойств." + ИмяСвойства);
    Исключение
    КонецПопытки;

    Возврат ЗначениеПоУмолчанию;

КонецФункции

Функция ПолучитьПервоеСвойство(Объект, ИменаСвойств)

    Для Каждого ИмяСвойства Из ИменаСвойств Цикл
        Значение = ПолучитьСвойствоОбъекта(Объект, ИмяСвойства, Неопределено);
        Если ЗначениеЗаполнено(Значение) Тогда
            Возврат Значение;
        КонецЕсли;
    КонецЦикла;

    Возврат "";

КонецФункции

Процедура ЗаписатьСтруктуруXML(Запись, ИмяЭлемента, Данные)

    Запись.ЗаписатьНачалоЭлемента(ИмяЭлемента);
    Для Каждого Элемент Из Данные Цикл
        ЗаписатьПростойЭлементXML(Запись, Элемент.Ключ, Элемент.Значение);
    КонецЦикла;
    Запись.ЗаписатьКонецЭлемента();

КонецПроцедуры

Процедура ЗаписатьПростойЭлементXML(Запись, ИмяЭлемента, Значение)

    Запись.ЗаписатьНачалоЭлемента(ИмяЭлемента);
    Запись.ЗаписатьТекст(ЗначениеВСтрокуXML(Значение));
    Запись.ЗаписатьКонецЭлемента();

КонецПроцедуры

Функция ЗначениеВСтрокуXML(Значение)

    Если Значение = Неопределено Тогда
        Возврат "";
    КонецЕсли;

    Если ТипЗнч(Значение) = Тип("Дата") Тогда
        Возврат Формат(Значение, "ДФ=dd.MM.yyyy HH:mm:ss");
    КонецЕсли;

    Возврат СокрЛП(Строка(Значение));

КонецФункции

Функция БулевоВСтроку(ЗначениеБулево)

    Возврат ?(ЗначениеВБулево(ЗначениеБулево, Ложь), "true", "false");

КонецФункции

Функция ЗначениеВБулево(Значение, ЗначениеПоУмолчанию = Ложь)

    Если Значение = Неопределено Тогда
        Возврат ЗначениеПоУмолчанию;
    КонецЕсли;

    ТипЗначения = ТипЗнч(Значение);

    Если ТипЗначения = Тип("Булево") Тогда
        Возврат Значение;
    КонецЕсли;

    Если ТипЗначения = Тип("Число") Тогда
        Возврат Значение <> 0;
    КонецЕсли;

    Если ТипЗначения = Тип("Строка") Тогда
        СтроковоеЗначение = ВРег(СокрЛП(Значение));
        Если СтроковоеЗначение = "TRUE"
           Или СтроковоеЗначение = "ИСТИНА"
           Или СтроковоеЗначение = "ДА"
           Или СтроковоеЗначение = "1" Тогда
            Возврат Истина;
        КонецЕсли;

        Если СтроковоеЗначение = "FALSE"
           Или СтроковоеЗначение = "ЛОЖЬ"
           Или СтроковоеЗначение = "НЕТ"
           Или СтроковоеЗначение = "0"
           Или СтроковоеЗначение = "" Тогда
            Возврат Ложь;
        КонецЕсли;
    КонецЕсли;

    Возврат ЗначениеПоУмолчанию;

КонецФункции

Функция ПолучитьПараметр(Параметры, ИмяПараметра, ЗначениеПоУмолчанию = Неопределено)

    ЗначениеПараметра = ЗначениеПоУмолчанию;
    Если Параметры.Свойство(ИмяПараметра, ЗначениеПараметра) Тогда
        Возврат ЗначениеПараметра;
    КонецЕсли;

    Возврат ЗначениеПоУмолчанию;

КонецФункции

Функция СоответствиеСодержитКлюч(СоответствиеОбъект, Ключ)

    Попытка
        Возврат СоответствиеОбъект.СодержитКлюч(Ключ);
    Исключение
    КонецПопытки;

    Значение = СоответствиеОбъект.Получить(Ключ);
    Возврат Значение <> Неопределено;

КонецФункции

Процедура ДобавитьВПротокол(Протокол, ТекстСообщения)

    Если Протокол <> Неопределено Тогда
        Протокол.Добавить(ТекстСообщения);
    КонецЕсли;

КонецПроцедуры

