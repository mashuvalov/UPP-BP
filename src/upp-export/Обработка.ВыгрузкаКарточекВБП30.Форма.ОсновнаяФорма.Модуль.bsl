    Данные.Вставить("КодКонтрагента", ?(ЗначениеЗаполнено(Владелец), ПолучитьКодСсылки(Владелец), ""));
    Данные.Вставить("Наименование", ПолучитьСвойствоОбъекта(Объект, "Наименование", ""));
    Данные.Вставить("НомерСчета", ПолучитьСвойствоОбъекта(Объект, "НомерСчета", ""));
    Данные.Вставить("Валютный", БулевоВСтроку(ЗначениеВБулево(ПолучитьСвойствоОбъекта(Объект, "Валютный", Ложь), Ложь)));
    Данные.Вставить("ДатаОткрытия", ПолучитьСвойствоОбъекта(Объект, "ДатаОткрытия", Неопределено));
    Данные.Вставить("ДатаЗакрытия", ПолучитьСвойствоОбъекта(Объект, "ДатаЗакрытия", Неопределено));
    Данные.Вставить("ВалютаКод", ?(ЗначениеЗаполнено(Валюта), ПолучитьКодСсылки(Валюта), ""));
    Данные.Вставить("Валюта", ?(ЗначениеЗаполнено(Валюта), ПолучитьСвойствоОбъекта(Валюта, "Наименование", ""), ""));
    Данные.Вставить("ВалютаПолноеНаименование", ?(ЗначениеЗаполнено(Валюта), ПолучитьСвойствоОбъекта(Валюта, "НаименованиеПолное", ""), ""));
    Данные.Вставить("БанкБИК", ?(ЗначениеЗаполнено(Банк), ПолучитьКодСсылки(Банк), ""));
    Данные.Вставить("БанкНаименование", ?(ЗначениеЗаполнено(Банк), ПолучитьСвойствоОбъекта(Банк, "Наименование", ""), ""));
    Данные.Вставить("БанкКоррСчет", ?(ЗначениеЗаполнено(Банк), ПолучитьСвойствоОбъекта(Банк, "КоррСчет", ""), ""));
    Данные.Вставить("БанкГород", ?(ЗначениеЗаполнено(Банк), ПолучитьСвойствоОбъекта(Банк, "Город", ""), ""));
    Данные.Вставить("БанкАдрес", ?(ЗначениеЗаполнено(Банк), ПолучитьСвойствоОбъекта(Банк, "Адрес", ""), ""));

