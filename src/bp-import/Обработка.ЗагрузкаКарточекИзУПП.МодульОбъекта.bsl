Процедура УстановитьСвойствоЕслиЕсть(Объект, ИмяСвойства, Значение)

    Если Объект = Неопределено Или Значение = Неопределено Тогда
        Возврат;
    КонецЕсли;

    Попытка
        Источник = Новый Структура;
        Источник.Вставить(ИмяСвойства, Значение);
        ЗаполнитьЗначенияСвойств(Объект, Источник);
        Возврат;
    Исключение
    КонецПопытки;

    Попытка
        Выполнить("Объект." + ИмяСвойства + " = Значение;");
    Исключение
    КонецПопытки;

КонецПроцедуры

Функция ПолучитьСвойствоОбъекта(Объект, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)

    Значение = ЗначениеПоУмолчанию;

    Если Объект = Неопределено Тогда
        Возврат ЗначениеПоУмолчанию;
    КонецЕсли;

    Попытка
        ПриемникСвойства = Новый Структура;
        ПриемникСвойства.Вставить(ИмяСвойства, ЗначениеПоУмолчанию);
        ЗаполнитьЗначенияСвойств(ПриемникСвойства, Объект);
        Если ПриемникСвойства.Свойство(ИмяСвойства, Значение) Тогда
            Возврат Значение;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        ОбъектСвойств = Объект.ПолучитьОбъект();
        ПриемникСвойства = Новый Структура;
        ПриемникСвойства.Вставить(ИмяСвойства, ЗначениеПоУмолчанию);
        ЗаполнитьЗначенияСвойств(ПриемникСвойства, ОбъектСвойств);
        Если ПриемникСвойства.Свойство(ИмяСвойства, Значение) Тогда
            Возврат Значение;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Возврат Вычислить("Объект." + ИмяСвойства);
    Исключение
    КонецПопытки;

    Попытка
        ОбъектСвойств = Объект.ПолучитьОбъект();
        Возврат Вычислить("ОбъектСвойств." + ИмяСвойства);
    Исключение
    КонецПопытки;

    Возврат ЗначениеПоУмолчанию;

КонецФункции

