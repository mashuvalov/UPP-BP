Функция ОпределитьТипКонтактнойИнформации(ПредставлениеИзФайла)

    Текст = НРег(СокрЛП(ПредставлениеИзФайла));

    Попытка
        Если СтрНайти(Текст, "mail") > 0 Или СтрНайти(Текст, "почт") > 0 Тогда
            Возврат Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
        ИначеЕсли СтрНайти(Текст, "тел") > 0 Тогда
            Возврат Перечисления.ТипыКонтактнойИнформации.Телефон;
        ИначеЕсли СтрНайти(Текст, "факс") > 0 Тогда
            Возврат Перечисления.ТипыКонтактнойИнформации.Факс;
        ИначеЕсли СтрНайти(Текст, "веб") > 0 Или СтрНайти(Текст, "сайт") > 0 Тогда
            Возврат Перечисления.ТипыКонтактнойИнформации.ВебСтраница;
        ИначеЕсли СтрНайти(Текст, "адрес") > 0 Или ПустаяСтрока(Текст) Тогда
            Возврат Перечисления.ТипыКонтактнойИнформации.Адрес;
        КонецЕсли;

        Возврат Перечисления.ТипыКонтактнойИнформации.Другое;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

Функция НайтиВидКонтактнойИнформации(ИмяВида, ТипКонтактнойИнформации)

    НаименованиеВида = НормализоватьИмяВидаКонтактнойИнформации(ИмяВида, ТипКонтактнойИнформации);

    СсылкаВида = НайтиВидКонтактнойИнформацииПоНаименованию(НаименованиеВида, ТипКонтактнойИнформации);
    Если ЗначениеЗаполнено(СсылкаВида) Тогда
        Возврат СсылкаВида;
    КонецЕсли;

    СсылкаВида = НайтиСтандартныйВидКонтактнойИнформации(НаименованиеВида, ТипКонтактнойИнформации);
    Если ЗначениеЗаполнено(СсылкаВида) Тогда
        Возврат СсылкаВида;
    КонецЕсли;

    Если ЭтоТипКонтактнойИнформацииАдрес(ТипКонтактнойИнформации) Тогда
        СсылкаВида = НайтиВидКонтактнойИнформацииПоНаименованию("Адрес", ТипКонтактнойИнформации);
        Если ЗначениеЗаполнено(СсылкаВида) Тогда
            Возврат СсылкаВида;
        КонецЕсли;
    КонецЕсли;

    Попытка
        ОбъектВида = Справочники.ВидыКонтактнойИнформации.СоздатьЭлемент();
        УстановитьСвойствоЕслиЕсть(ОбъектВида, "Наименование", НаименованиеВида);
        УстановитьСвойствоЕслиЕсть(ОбъектВида, "Тип", ТипКонтактнойИнформации);
        УстановитьСвойствоЕслиЕсть(ОбъектВида, "Используется", Истина);
        ОбъектВида.Записать();
        Возврат ОбъектВида.Ссылка;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

Функция НайтиВидКонтактнойИнформацииПоНаименованию(НаименованиеВида, ТипКонтактнойИнформации)

    ТекстЗапроса =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   ВидыКонтактнойИнформации.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.ВидыКонтактнойИнформации КАК ВидыКонтактнойИнформации
        |ГДЕ
        |   ВидыКонтактнойИнформации.Наименование = &Наименование";
    Если ЗначениеЗаполнено(ТипКонтактнойИнформации) Тогда
        ТекстЗапроса = ТекстЗапроса + "
        |   И ВидыКонтактнойИнформации.Тип = &Тип";
    КонецЕсли;

    Запрос = Новый Запрос(ТекстЗапроса);
    Запрос.УстановитьПараметр("Наименование", НаименованиеВида);
    Если ЗначениеЗаполнено(ТипКонтактнойИнформации) Тогда
        Запрос.УстановитьПараметр("Тип", ТипКонтактнойИнформации);
    КонецЕсли;

    Попытка
        Выборка = Запрос.Выполнить().Выбрать();
        Если Выборка.Следующий() Тогда
            Возврат Выборка.Ссылка;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат Неопределено;

КонецФункции

Функция НайтиСтандартныйВидКонтактнойИнформации(НаименованиеВида, ТипКонтактнойИнформации)

    Если Не ЭтоТипКонтактнойИнформацииАдрес(ТипКонтактнойИнформации) Тогда
        Возврат Неопределено;
    КонецЕсли;

    Для Каждого ВариантНаименования Из ПолучитьВариантыНаименованийВидаКонтактнойИнформации(НаименованиеВида) Цикл
        СсылкаВида = НайтиВидКонтактнойИнформацииПоНаименованию(ВариантНаименования, ТипКонтактнойИнформации);
        Если ЗначениеЗаполнено(СсылкаВида) Тогда
            Возврат СсылкаВида;
        КонецЕсли;
    КонецЦикла;

    ПоисковыеФрагменты = ПолучитьПоисковыеФрагментыВидаКонтактнойИнформации(НаименованиеВида);
    Если ПоисковыеФрагменты.Количество() = 0 Тогда
        Возврат Неопределено;
    КонецЕсли;

    Попытка
        Выборка = Справочники.ВидыКонтактнойИнформации.Выбрать();
        Пока Выборка.Следующий() Цикл
            Если ЗначениеЗаполнено(ТипКонтактнойИнформации)
               И ПолучитьСвойствоОбъекта(Выборка.Ссылка, "Тип", Неопределено) <> ТипКонтактнойИнформации Тогда
                Продолжить;
            КонецЕсли;

            НаименованиеСуществующегоВида = НРег(СокрЛП(Выборка.Наименование));
            Для Каждого Фрагмент Из ПоисковыеФрагменты Цикл
                Если СтрНайти(НаименованиеСуществующегоВида, Фрагмент) > 0 Тогда
                    Возврат Выборка.Ссылка;
                КонецЕсли;
            КонецЦикла;
        КонецЦикла;
    Исключение
    КонецПопытки;

    Возврат Неопределено;

КонецФункции

Функция ПолучитьВариантыНаименованийВидаКонтактнойИнформации(НаименованиеВида)

    Варианты = Новый Массив;
    ДобавитьВариантЕслиНовый(Варианты, НаименованиеВида);

    НаименованиеНиж = НРег(СокрЛП(НаименованиеВида));
    Если СтрНайти(НаименованиеНиж, "юрид") > 0 Тогда
        ДобавитьВариантЕслиНовый(Варианты, "Юридический адрес");
        ДобавитьВариантЕслиНовый(Варианты, "Юридический адрес организации");
    ИначеЕсли СтрНайти(НаименованиеНиж, "почт") > 0 Тогда
        ДобавитьВариантЕслиНовый(Варианты, "Почтовый адрес");
    ИначеЕсли СтрНайти(НаименованиеНиж, "факт") > 0 Тогда
        ДобавитьВариантЕслиНовый(Варианты, "Фактический адрес");
        ДобавитьВариантЕслиНовый(Варианты, "Фактический адрес организации");
    ИначеЕсли СтрНайти(НаименованиеНиж, "достав") > 0 Тогда
        ДобавитьВариантЕслиНовый(Варианты, "Адрес доставки");
    ИначеЕсли СтрНайти(НаименованиеНиж, "адрес") > 0 Тогда
        ДобавитьВариантЕслиНовый(Варианты, "Адрес");
    КонецЕсли;

    Возврат Варианты;

КонецФункции

Функция ПолучитьПоисковыеФрагментыВидаКонтактнойИнформации(НаименованиеВида)

    Фрагменты = Новый Массив;
    НаименованиеНиж = НРег(СокрЛП(НаименованиеВида));

    Если СтрНайти(НаименованиеНиж, "юрид") > 0 Тогда
        ДобавитьВариантЕслиНовый(Фрагменты, "юрид");
    ИначеЕсли СтрНайти(НаименованиеНиж, "почт") > 0 Тогда
        ДобавитьВариантЕслиНовый(Фрагменты, "почт");
    ИначеЕсли СтрНайти(НаименованиеНиж, "факт") > 0 Тогда
        ДобавитьВариантЕслиНовый(Фрагменты, "факт");
    ИначеЕсли СтрНайти(НаименованиеНиж, "достав") > 0 Тогда
        ДобавитьВариантЕслиНовый(Фрагменты, "достав");
    ИначеЕсли СтрНайти(НаименованиеНиж, "адрес") > 0 Тогда
        ДобавитьВариантЕслиНовый(Фрагменты, "адрес");
    КонецЕсли;

    Возврат Фрагменты;

КонецФункции

Процедура ДобавитьВариантЕслиНовый(МассивЗначений, Значение)

    Если ПустаяСтрока(СокрЛП(Значение)) Тогда
        Возврат;
    КонецЕсли;

    Для Каждого ТекущееЗначение Из МассивЗначений Цикл
        Если ТекущееЗначение = Значение Тогда
            Возврат;
        КонецЕсли;
    КонецЦикла;

    МассивЗначений.Добавить(Значение);

КонецПроцедуры

Функция ЭтоТипКонтактнойИнформацииАдрес(ТипКонтактнойИнформации)

    Если Не ЗначениеЗаполнено(ТипКонтактнойИнформации) Тогда
        Возврат Ложь;
    КонецЕсли;

    Попытка
        Возврат ТипКонтактнойИнформации = Перечисления.ТипыКонтактнойИнформации.Адрес;
    Исключение
        Возврат Ложь;
    КонецПопытки;

КонецФункции

Функция НормализоватьИмяВидаКонтактнойИнформации(ИмяВида, ТипКонтактнойИнформации)

    НаименованиеВида = СокрЛП(ПолучитьПервуюНепустуюСтроку(ИмяВида, Строка(ТипКонтактнойИнформации), "Адрес"));
    НаименованиеНиж = НРег(НаименованиеВида);

    Пока СтрДлина(НаименованиеВида) > 0 Цикл
        ПервыйСимвол = Лев(НаименованиеВида, 1);
        Если СтрНайти("0123456789 ._-", ПервыйСимвол) > 0 Тогда
            НаименованиеВида = СокрЛП(Сред(НаименованиеВида, 2));
            НаименованиеНиж = НРег(НаименованиеВида);
        Иначе
            Прервать;
        КонецЕсли;
    КонецЦикла;

    Если ЗначениеЗаполнено(ТипКонтактнойИнформации) Тогда
        Попытка
            Если ЭтоТипКонтактнойИнформацииАдрес(ТипКонтактнойИнформации) Тогда
                Если СтрНайти(НаименованиеНиж, "юрид") > 0 Тогда
                    Возврат "Юридический адрес";
                ИначеЕсли СтрНайти(НаименованиеНиж, "почт") > 0 Тогда
                    Возврат "Почтовый адрес";
                ИначеЕсли СтрНайти(НаименованиеНиж, "факт") > 0 Тогда
                    Возврат "Фактический адрес";
                ИначеЕсли СтрНайти(НаименованиеНиж, "достав") > 0 Тогда
                    Возврат "Адрес доставки";
                ИначеЕсли СтрНайти(НаименованиеНиж, "адрес") > 0 Тогда
                    Возврат "Адрес";
                КонецЕсли;
            КонецЕсли;
        Исключение
        КонецПопытки;
    КонецЕсли;

    Если СтрНайти(НаименованиеНиж, "контрагента") > 0 Тогда
        НаименованиеВида = СокрЛП(СтрЗаменить(НаименованиеВида, "Контрагента", ""));
        НаименованиеВида = СокрЛП(СтрЗаменить(НаименованиеВида, "контрагента", ""));
    КонецЕсли;

    Если ПустаяСтрока(НаименованиеВида) Тогда
        Возврат "Адрес";
    КонецЕсли;

    Возврат НаименованиеВида;

КонецФункции

Функция НайтиСтрокуКонтактнойИнформации(ТабличнаяЧасть, ТипКонтактнойИнформации, ВидКонтактнойИнформации, Представление)

    Для Каждого СтрокаКонтактнойИнформации Из ТабличнаяЧасть Цикл
        Если ЗначениеЗаполнено(ТипКонтактнойИнформации)
           И ПолучитьСвойствоОбъекта(СтрокаКонтактнойИнформации, "Тип", Неопределено) <> ТипКонтактнойИнформации Тогда
            Продолжить;
        КонецЕсли;

        Если ЗначениеЗаполнено(ВидКонтактнойИнформации)
           И ПолучитьСвойствоОбъекта(СтрокаКонтактнойИнформации, "Вид", Неопределено) <> ВидКонтактнойИнформации Тогда
            Продолжить;
        КонецЕсли;

        Если СокрЛП(Строка(ПолучитьСвойствоОбъекта(СтрокаКонтактнойИнформации, "Представление", ""))) = Представление Тогда
            Возврат СтрокаКонтактнойИнформации;
        КонецЕсли;
    КонецЦикла;

    Возврат Неопределено;

КонецФункции

Функция ПодготовитьПредставлениеКонтактнойИнформации(ДанныеКонтактнойИнформации)

    Представление = ПолучитьСтроку(ДанныеКонтактнойИнформации, "Представление");
    Если Не ПустаяСтрока(Представление) Тогда
        Возврат Представление;
    КонецЕсли;

    Возврат СобратьСтрокуКонтактнойИнформацииИзПолей(ДанныеКонтактнойИнформации);

КонецФункции

Функция ПолучитьПредставлениеВидаКонтактнойИнформации(ДанныеКонтактнойИнформации, ВидКонтактнойИнформации)

    Возврат ПолучитьПервуюНепустуюСтроку(
        ПолучитьСтроку(ДанныеКонтактнойИнформации, "Вид"),
        ?(ЗначениеЗаполнено(ВидКонтактнойИнформации), Строка(ВидКонтактнойИнформации), ""),
        "Адрес");

КонецФункции

Процедура ЗаполнитьПоляАдресаКонтрагента(СтрокаКонтактнойИнформации, ДанныеАдреса)

    УстановитьСвойствоЕслиЕсть(СтрокаКонтактнойИнформации, "Страна", ПолучитьСтроку(ДанныеАдреса, "Поле3"));
    УстановитьСвойствоЕслиЕсть(СтрокаКонтактнойИнформации, "Регион", ПолучитьСтроку(ДанныеАдреса, "Поле2"));
    УстановитьСвойствоЕслиЕсть(СтрокаКонтактнойИнформации, "Город", ПолучитьСтроку(ДанныеАдреса, "Поле4"));

КонецПроцедуры

Функция СобратьСтрокуКонтактнойИнформацииИзПолей(ДанныеКонтактнойИнформации)

    Части = Новый Массив;

    Для НомерПоля = 1 По 10 Цикл
        ЗначениеПоля = ПолучитьСтроку(ДанныеКонтактнойИнформации, "Поле" + Строка(НомерПоля));
        Если ПустаяСтрока(ЗначениеПоля) Тогда
            Продолжить;
        КонецЕсли;

        Если Части.Найти(ЗначениеПоля) = Неопределено Тогда
            Части.Добавить(ЗначениеПоля);
        КонецЕсли;
    КонецЦикла;

    Возврат СоединитьСтроки(Части, ", ");

КонецФункции

Функция СоединитьСтроки(Строки, Разделитель = ", ")

    Результат = "";

    Для Каждого ЗначениеСтроки Из Строки Цикл
        Если ПустаяСтрока(ЗначениеСтроки) Тогда
            Продолжить;
        КонецЕсли;

        Если ПустаяСтрока(Результат) Тогда
            Результат = ЗначениеСтроки;
        Иначе
            Результат = Результат + Разделитель + ЗначениеСтроки;
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция НайтиБанковскийСчетКонтрагента(СсылкаКонтрагента, НомерСчета)

    Запрос = Новый Запрос(
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   БанковскиеСчета.Ссылка КАК Ссылка
        |ИЗ
        |   Справочник.БанковскиеСчета КАК БанковскиеСчета
        |ГДЕ
        |   БанковскиеСчета.Владелец = &Владелец
        |   И БанковскиеСчета.НомерСчета = &НомерСчета");
    Запрос.УстановитьПараметр("Владелец", СсылкаКонтрагента);
    Запрос.УстановитьПараметр("НомерСчета", НомерСчета);

    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Ссылка;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

Процедура УстановитьОсновнойБанковскийСчетКонтрагента(СсылкаКонтрагента, СсылкаБанковскогоСчета)

    Если Не ЗначениеЗаполнено(СсылкаКонтрагента) Или Не ЗначениеЗаполнено(СсылкаБанковскогоСчета) Тогда
        Возврат;
    КонецЕсли;

    Попытка
        ОбъектКонтрагента = СсылкаКонтрагента.ПолучитьОбъект();
    Исключение
        Возврат;
    КонецПопытки;

    ТекущийОсновнойСчет = ПолучитьСвойствоОбъекта(ОбъектКонтрагента, "ОсновнойБанковскийСчет", Неопределено);
    Если ЗначениеЗаполнено(ТекущийОсновнойСчет) Тогда
        Возврат;
    КонецЕсли;

    Попытка
        УстановитьСвойствоЕслиЕсть(ОбъектКонтрагента, "ОсновнойБанковскийСчет", СсылкаБанковскогоСчета);
        ОбъектКонтрагента.Записать();
    Исключение
    КонецПопытки;

КонецПроцедуры

Функция НайтиИлиСоздатьБанк(БИК, Наименование, КоррСчет, Город, Адрес)

    КодБанка = ПодготовитьКодБанка(БИК);

    Если Не ПустаяСтрока(КодБанка) Тогда
        СсылкаБанка = Справочники.Банки.НайтиПоКоду(КодБанка);
        Если ЗначениеЗаполнено(СсылкаБанка) И Не ЭтоГруппаСсылки(СсылкаБанка) Тогда
            Возврат СсылкаБанка;
        КонецЕсли;
    КонецЕсли;

    Если Не ПустаяСтрока(Наименование) Тогда
        СсылкаБанка = Справочники.Банки.НайтиПоНаименованию(Наименование);
        Если ЗначениеЗаполнено(СсылкаБанка) И Не ЭтоГруппаСсылки(СсылкаБанка) Тогда
            Возврат СсылкаБанка;
        КонецЕсли;
    КонецЕсли;

    Если ПустаяСтрока(КодБанка) Тогда
        Возврат Неопределено;
    КонецЕсли;

    Попытка
        ОбъектБанка = Справочники.Банки.СоздатьЭлемент();
        УстановитьСвойствоЕслиЕсть(ОбъектБанка, "Код", КодБанка);
        УстановитьСвойствоЕслиЕсть(ОбъектБанка, "Наименование", ПолучитьПервуюНепустуюСтроку(Наименование, КодБанка));
        УстановитьСвойствоЕслиЕсть(ОбъектБанка, "КоррСчет", КоррСчет);
        УстановитьСвойствоЕслиЕсть(ОбъектБанка, "Город", Город);
        УстановитьСвойствоЕслиЕсть(ОбъектБанка, "Адрес", Адрес);
        ОбъектБанка.Записать();
        Возврат ОбъектБанка.Ссылка;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

Функция ПодготовитьКодБанка(КодБанка)

    Результат = СокрЛП(КодБанка);
    Результат = СтрЗаменить(Результат, " ", "");
    Возврат Лев(Результат, 9);

КонецФункции

Функция НайтиВалюту(КодВалюты, НаименованиеВалюты, ПолноеНаименованиеВалюты = "")

    СсылкаВалюты = НайтиВалютуБезСоздания(КодВалюты, НаименованиеВалюты, ПолноеНаименованиеВалюты);
    Если ЗначениеЗаполнено(СсылкаВалюты) Тогда
        Возврат СсылкаВалюты;
    КонецЕсли;

    Возврат НайтиВалютуПоУмолчанию();

КонецФункции

Функция НайтиВалютуПоУмолчанию()

    СсылкаВалюты = НайтиВалютуБезСоздания("643", "RUB", "Российский рубль");
    Если ЗначениеЗаполнено(СсылкаВалюты) Тогда
        Возврат СсылкаВалюты;
    КонецЕсли;

    Попытка
        Выборка = Справочники.Валюты.Выбрать();
        Пока Выборка.Следующий() Цикл
            Если Не ЭтоГруппаСсылки(Выборка.Ссылка) Тогда
                Возврат Выборка.Ссылка;
            КонецЕсли;
        КонецЦикла;
    Исключение
    КонецПопытки;

    Возврат Неопределено;

КонецФункции

Функция НайтиВалютуБезСоздания(КодВалюты, НаименованиеВалюты, ПолноеНаименованиеВалюты = "")

    Попытка
        Если Не ПустаяСтрока(КодВалюты) Тогда
            СсылкаВалюты = Справочники.Валюты.НайтиПоКоду(СокрЛП(КодВалюты));
            Если ЗначениеЗаполнено(СсылкаВалюты) И Не ЭтоГруппаСсылки(СсылкаВалюты) Тогда
                Возврат СсылкаВалюты;
            КонецЕсли;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Если Не ПустаяСтрока(НаименованиеВалюты) Тогда
            СсылкаВалюты = Справочники.Валюты.НайтиПоНаименованию(СокрЛП(НаименованиеВалюты));
            Если ЗначениеЗаполнено(СсылкаВалюты) И Не ЭтоГруппаСсылки(СсылкаВалюты) Тогда
                Возврат СсылкаВалюты;
            КонецЕсли;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Если Не ПустаяСтрока(ПолноеНаименованиеВалюты) Тогда
            Выборка = Справочники.Валюты.Выбрать();
            Пока Выборка.Следующий() Цикл
                Если ЭтоГруппаСсылки(Выборка.Ссылка) Тогда
                    Продолжить;
                КонецЕсли;

                Если СокрЛП(Строка(ПолучитьСвойствоОбъекта(Выборка.Ссылка.ПолучитьОбъект(), "НаименованиеПолное", ""))) = СокрЛП(ПолноеНаименованиеВалюты) Тогда
                    Возврат Выборка.Ссылка;
                КонецЕсли;
            КонецЦикла;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат Неопределено;

КонецФункции

Функция НайтиНоменклатуруПоШтрихкоду(Штрихкод)

    Запрос = Новый Запрос(
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   ШтрихкодыНоменклатуры.Номенклатура КАК Номенклатура
        |ИЗ
        |   РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
        |ГДЕ
