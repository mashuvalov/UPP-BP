Функция ОпределитьСтавкуНДС(СтрокаСтавки)

    ПредставлениеСтавки = НРег(СокрЛП(СтрокаСтавки));

    Если ПустаяСтрока(ПредставлениеСтавки) Тогда
        Возврат Неопределено;
    КонецЕсли;

    Попытка
        Если СтрНайти(ПредставлениеСтавки, "без") > 0 Тогда
            Возврат Перечисления.СтавкиНДС.БезНДС;
        ИначеЕсли СтрНайти(ПредставлениеСтавки, "20") > 0 Тогда
            Возврат Перечисления.СтавкиНДС.НДС20;
        ИначеЕсли СтрНайти(ПредставлениеСтавки, "18") > 0 Тогда
            Возврат Перечисления.СтавкиНДС.НДС18;
        ИначеЕсли СтрНайти(ПредставлениеСтавки, "10") > 0 Тогда
            Возврат Перечисления.СтавкиНДС.НДС10;
        ИначеЕсли СтрНайти(ПредставлениеСтавки, "0") > 0 Тогда
            Возврат Перечисления.СтавкиНДС.НДС0;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат Неопределено;

