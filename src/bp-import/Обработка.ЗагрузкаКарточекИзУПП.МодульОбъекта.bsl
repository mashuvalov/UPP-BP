Функция НайтиВидНоменклатуры(ИмяВидаИзФайла, ВидПоУмолчанию, ЭтоУслуга = Ложь)

    ИмяПоискаПоНазначению = ?(ЭтоУслуга, "Услуга", ВидПоУмолчанию);
    ИмяПоиска = ИмяПоискаПоНазначению;
    Если ПустаяСтрока(СокрЛП(ИмяПоиска)) Тогда
        ИмяПоиска = ?(ПустаяСтрока(СокрЛП(ИмяВидаИзФайла)), "Товар", ИмяВидаИзФайла);
    КонецЕсли;

    Попытка
        СсылкаВида = Справочники.ВидыНоменклатуры.НайтиПоНаименованию(ИмяПоиска);
    Исключение
        СсылкаВида = Неопределено;
    КонецПопытки;

    Если ЗначениеЗаполнено(СсылкаВида) И Не ЭтоГруппаСсылки(СсылкаВида) Тогда
        Возврат СсылкаВида;
    КонецЕсли;

    ИмяВидаИзФайла = СокрЛП(ИмяВидаИзФайла);
    Если Не ПустаяСтрока(ИмяВидаИзФайла) И ИмяВидаИзФайла <> ИмяПоиска Тогда
        Попытка
            СсылкаВида = Справочники.ВидыНоменклатуры.НайтиПоНаименованию(ИмяВидаИзФайла);
        Исключение
            СсылкаВида = Неопределено;
        КонецПопытки;

        Если ЗначениеЗаполнено(СсылкаВида) И Не ЭтоГруппаСсылки(СсылкаВида) Тогда
            Возврат СсылкаВида;
        КонецЕсли;
    КонецЕсли;

    Попытка
        ОбъектВида = Справочники.ВидыНоменклатуры.СоздатьЭлемент();
        УстановитьСвойствоЕслиЕсть(ОбъектВида, "Наименование", ИмяПоиска);
        УстановитьСвойствоЕслиЕсть(ОбъектВида, "Услуга", ЭтоУслуга);
        ОбъектВида.Записать();
        Возврат ОбъектВида.Ссылка;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

Функция НайтиЕдиницуИзмерения(КодЕдиницы, НаименованиеЕдиницы, ПолноеНаименованиеЕдиницы = "")

    СсылкаЕдиницы = НайтиЕдиницуИзмеренияБезСоздания(КодЕдиницы, НаименованиеЕдиницы, ПолноеНаименованиеЕдиницы);
    Если ЗначениеЗаполнено(СсылкаЕдиницы) Тогда
        Возврат СсылкаЕдиницы;
    КонецЕсли;

    Попытка
        ОбъектЕдиницы = Справочники.КлассификаторЕдиницИзмерения.СоздатьЭлемент();
        УстановитьСвойствоЕслиЕсть(ОбъектЕдиницы, "Код", ПодобратьКодЕдиницыИзмерения(КодЕдиницы, НаименованиеЕдиницы, ПолноеНаименованиеЕдиницы));
        УстановитьСвойствоЕслиЕсть(ОбъектЕдиницы, "Наименование", ПолучитьНаименованиеЕдиницы(НаименованиеЕдиницы, ПолноеНаименованиеЕдиницы));
        УстановитьСвойствоЕслиЕсть(ОбъектЕдиницы, "НаименованиеПолное", ПолучитьПолноеНаименованиеЕдиницы(НаименованиеЕдиницы, ПолноеНаименованиеЕдиницы));
        ОбъектЕдиницы.Записать();
        Возврат ОбъектЕдиницы.Ссылка;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

Функция НайтиЕдиницуИзмеренияБезСоздания(КодЕдиницы, НаименованиеЕдиницы, ПолноеНаименованиеЕдиницы = "")

    Попытка
        Если Не ПустаяСтрока(КодЕдиницы) Тогда
            СсылкаЕдиницы = Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду(ПодготовитьКодЕдиницыИзмерения(КодЕдиницы, НаименованиеЕдиницы, ПолноеНаименованиеЕдиницы));
            Если ЗначениеЗаполнено(СсылкаЕдиницы) И Не ЭтоГруппаСсылки(СсылкаЕдиницы) Тогда
                Возврат СсылкаЕдиницы;
            КонецЕсли;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Если Не ПустаяСтрока(НаименованиеЕдиницы) Тогда
            СсылкаЕдиницы = Справочники.КлассификаторЕдиницИзмерения.НайтиПоНаименованию(НаименованиеЕдиницы);
            Если ЗначениеЗаполнено(СсылкаЕдиницы) И Не ЭтоГруппаСсылки(СсылкаЕдиницы) Тогда
                Возврат СсылкаЕдиницы;
            КонецЕсли;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Если Не ПустаяСтрока(ПолноеНаименованиеЕдиницы) Тогда
            Выборка = Справочники.КлассификаторЕдиницИзмерения.Выбрать();
            Пока Выборка.Следующий() Цикл
                Если ЭтоГруппаСсылки(Выборка.Ссылка) Тогда
                    Продолжить;
                КонецЕсли;

                Если СокрЛП(Строка(ПолучитьСвойствоОбъекта(Выборка.Ссылка.ПолучитьОбъект(), "НаименованиеПолное", ""))) = СокрЛП(ПолноеНаименованиеЕдиницы) Тогда
                    Возврат Выборка.Ссылка;
                КонецЕсли;
            КонецЦикла;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат Неопределено;

КонецФункции

Функция ПодобратьКодЕдиницыИзмерения(КодЕдиницы, НаименованиеЕдиницы, ПолноеНаименованиеЕдиницы)

    БазовыйКод = ПодготовитьКодЕдиницыИзмерения(КодЕдиницы, НаименованиеЕдиницы, ПолноеНаименованиеЕдиницы);
    Если ПустаяСтрока(БазовыйКод) Тогда
        БазовыйКод = "0000";
    КонецЕсли;

    Кандидат = БазовыйКод;
    Счетчик = 1;

    Пока ЗначениеЗаполнено(Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду(Кандидат)) Цикл
        Суффикс = Строка(Счетчик);
        Кандидат = Лев(БазовыйКод, 4 - СтрДлина(Суффикс)) + Суффикс;
        Счетчик = Счетчик + 1;
        Если Счетчик > 999 Тогда
            Возврат БазовыйКод;
        КонецЕсли;
    КонецЦикла;

    Возврат Кандидат;

КонецФункции

Функция ПодготовитьКодЕдиницыИзмерения(КодЕдиницы, НаименованиеЕдиницы, ПолноеНаименованиеЕдиницы)

    Результат = СокрЛП(КодЕдиницы);
    Если ПустаяСтрока(Результат) Тогда
        Результат = СокрЛП(НаименованиеЕдиницы);
    КонецЕсли;
    Если ПустаяСтрока(Результат) Тогда
        Результат = СокрЛП(ПолноеНаименованиеЕдиницы);
    КонецЕсли;

    Результат = СтрЗаменить(Результат, " ", "");
    Возврат Лев(Результат, 4);

КонецФункции

Функция ПолучитьНаименованиеЕдиницы(НаименованиеЕдиницы, ПолноеНаименованиеЕдиницы)

