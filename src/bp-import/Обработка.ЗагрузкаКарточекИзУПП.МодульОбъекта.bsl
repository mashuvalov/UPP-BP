Функция ВыполнитьЗагрузку(Параметры, Протокол = Неопределено) Экспорт

    Если Протокол = Неопределено Тогда
        Протокол = Новый Массив;
    КонецЕсли;

    ИмяФайла = СокрЛП(ПолучитьПараметр(Параметры, "ИмяФайла", ""));
    Если ПустаяСтрока(ИмяФайла) Тогда
        ВызватьИсключение "Не указан файл XML для загрузки.";
    КонецЕсли;

    ВидНоменклатурыПоУмолчанию = ПолучитьПараметр(Параметры, "ВидНоменклатурыПоУмолчанию", "Товар");
    ПерезаписыватьНаименование = ПолучитьПараметр(Параметры, "ПерезаписыватьНаименование", Истина);

    ПакетОбмена = ПрочитатьПакетОбмена(ИмяФайла);

    ИндексКонтрагентов = ИндексироватьПоКоду(ПакетОбмена.Контрагенты);
    ИндексНоменклатуры = ИндексироватьПоКоду(ПакетОбмена.Номенклатура);

    ЗагруженныеКонтрагенты = Новый Соответствие;
    ЗагруженнаяНоменклатура = Новый Соответствие;
    КоличествоАдресовКонтрагентов = 0;
    КоличествоБанковскихСчетов = 0;
    КоличествоШтрихкодов = 0;

    Для Каждого ДанныеКонтрагента Из ПакетОбмена.Контрагенты Цикл
        ИмпортироватьКонтрагента(ДанныеКонтрагента, ИндексКонтрагентов, ЗагруженныеКонтрагенты, ПерезаписыватьНаименование, Протокол);
    КонецЦикла;

    Для Каждого ДанныеАдреса Из ПакетОбмена.АдресаКонтрагентов Цикл
        Если ИмпортироватьАдресКонтрагента(ДанныеАдреса, ЗагруженныеКонтрагенты, Протокол) Тогда
            КоличествоАдресовКонтрагентов = КоличествоАдресовКонтрагентов + 1;
        КонецЕсли;
    КонецЦикла;

    Для Каждого ДанныеБанковскогоСчета Из ПакетОбмена.БанковскиеСчетаКонтрагентов Цикл
        Если ИмпортироватьБанковскийСчетКонтрагента(ДанныеБанковскогоСчета, ЗагруженныеКонтрагенты, Протокол) Тогда
            КоличествоБанковскихСчетов = КоличествоБанковскихСчетов + 1;
        КонецЕсли;
    КонецЦикла;

    Для Каждого ДанныеНоменклатуры Из ПакетОбмена.Номенклатура Цикл
        ИмпортироватьНоменклатуру(ДанныеНоменклатуры, ИндексНоменклатуры, ЗагруженнаяНоменклатура, ВидНоменклатурыПоУмолчанию, ПерезаписыватьНаименование, Протокол);
    КонецЦикла;

    Для Каждого ДанныеШтрихкода Из ПакетОбмена.ШтрихкодыНоменклатуры Цикл
        Если ИмпортироватьШтрихкодНоменклатуры(ДанныеШтрихкода, ЗагруженнаяНоменклатура, Протокол) Тогда
            КоличествоШтрихкодов = КоличествоШтрихкодов + 1;
        КонецЕсли;
    КонецЦикла;

    Результат = Новый Структура;
    Результат.Вставить("КоличествоКонтрагентов", ЗагруженныеКонтрагенты.Количество());
    Результат.Вставить("КоличествоАдресовКонтрагентов", КоличествоАдресовКонтрагентов);
    Результат.Вставить("КоличествоБанковскихСчетов", КоличествоБанковскихСчетов);
    Результат.Вставить("КоличествоНоменклатуры", ЗагруженнаяНоменклатура.Количество());
    Результат.Вставить("КоличествоШтрихкодов", КоличествоШтрихкодов);

    Возврат Результат;

КонецФункции

Функция ПрочитатьПакетОбмена(ИмяФайла)

    Результат = Новый Структура;
    Результат.Вставить("Контрагенты", Новый Массив);
    Результат.Вставить("АдресаКонтрагентов", Новый Массив);
    Результат.Вставить("БанковскиеСчетаКонтрагентов", Новый Массив);
    Результат.Вставить("Номенклатура", Новый Массив);
    Результат.Вставить("ШтрихкодыНоменклатуры", Новый Массив);

    Чтение = Новый ЧтениеXML;
    Чтение.ОткрытьФайл(ИмяФайла);

    ТекущаяСтрока = Неопределено;

    Пока Чтение.Прочитать() Цикл

        Если Чтение.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда

            Если Чтение.Имя = "Контрагент"
               Или Чтение.Имя = "АдресКонтрагента"
               Или Чтение.Имя = "БанковскийСчет"
               Или Чтение.Имя = "Номенклатура"
               Или Чтение.Имя = "ШтрихкодНоменклатуры" Тогда
                ТекущаяСтрока = Новый Структура;
            ИначеЕсли ТекущаяСтрока <> Неопределено Тогда
                ТекущаяСтрока.Вставить(Чтение.Имя, ПрочитатьТекстЭлементаXML(Чтение));
            КонецЕсли;

        ИначеЕсли Чтение.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда

            Если Чтение.Имя = "Контрагент" И ТекущаяСтрока <> Неопределено Тогда
                Результат.Контрагенты.Добавить(ТекущаяСтрока);
                ТекущаяСтрока = Неопределено;
            ИначеЕсли Чтение.Имя = "АдресКонтрагента" И ТекущаяСтрока <> Неопределено Тогда
                Результат.АдресаКонтрагентов.Добавить(ТекущаяСтрока);
                ТекущаяСтрока = Неопределено;
            ИначеЕсли Чтение.Имя = "БанковскийСчет" И ТекущаяСтрока <> Неопределено Тогда
                Результат.БанковскиеСчетаКонтрагентов.Добавить(ТекущаяСтрока);
                ТекущаяСтрока = Неопределено;
            ИначеЕсли Чтение.Имя = "Номенклатура" И ТекущаяСтрока <> Неопределено Тогда
                Результат.Номенклатура.Добавить(ТекущаяСтрока);
                ТекущаяСтрока = Неопределено;
            ИначеЕсли Чтение.Имя = "ШтрихкодНоменклатуры" И ТекущаяСтрока <> Неопределено Тогда
                Результат.ШтрихкодыНоменклатуры.Добавить(ТекущаяСтрока);
                ТекущаяСтрока = Неопределено;
            КонецЕсли;

        КонецЕсли;

    КонецЦикла;

    Возврат Результат;

КонецФункции

Функция ПрочитатьТекстЭлементаXML(Чтение)

    ЗначениеЭлемента = "";

    Пока Чтение.Прочитать() Цикл
        Если Чтение.ТипУзла = ТипУзлаXML.Текст Тогда
            ЗначениеЭлемента = Чтение.Значение;
        ИначеЕсли Чтение.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда
            Возврат ЗначениеЭлемента;
        КонецЕсли;
    КонецЦикла;

    Возврат ЗначениеЭлемента;

КонецФункции

Функция ИндексироватьПоКоду(МассивСтрок)

    Индекс = Новый Соответствие;
    Для Каждого СтрокаДанных Из МассивСтрок Цикл
        Код = ПолучитьСтроку(СтрокаДанных, "Код");
        Если Не ПустаяСтрока(Код) Тогда
            Индекс.Вставить(Код, СтрокаДанных);
        КонецЕсли;
    КонецЦикла;

    Возврат Индекс;

КонецФункции

Функция ИмпортироватьКонтрагента(ДанныеКонтрагента, ИндексКонтрагентов, ЗагруженныеКонтрагенты, ПерезаписыватьНаименование, Протокол)

    Код = ПолучитьСтроку(ДанныеКонтрагента, "Код");
    Если ПустаяСтрока(Код) Тогда
        Возврат Неопределено;
    КонецЕсли;

    Если СоответствиеСодержитКлюч(ЗагруженныеКонтрагенты, Код) Тогда
        Возврат ЗагруженныеКонтрагенты.Получить(Код);
    КонецЕсли;

    Родитель = ПолучитьСсылкуРодителяКонтрагента(ДанныеКонтрагента, ИндексКонтрагентов, ЗагруженныеКонтрагенты, ПерезаписыватьНаименование, Протокол);
    ЭтоГруппа = ЭтоИстина(ПолучитьСтроку(ДанныеКонтрагента, "ЭтоГруппа"));

    СсылкаКонтрагента = НайтиКонтрагента(ДанныеКонтрагента, ЭтоГруппа);
    Если ЗначениеЗаполнено(СсылкаКонтрагента) Тогда
        ОбъектКонтрагента = СсылкаКонтрагента.ПолучитьОбъект();
    ИначеЕсли ЭтоГруппа Тогда
        ОбъектКонтрагента = Справочники.Контрагенты.СоздатьГруппу();
    Иначе
        ОбъектКонтрагента = Справочники.Контрагенты.СоздатьЭлемент();
    КонецЕсли;

    УстановитьСвойствоЕслиЕсть(ОбъектКонтрагента, "Родитель", Родитель);
    УстановитьСвойствоЕслиЕсть(ОбъектКонтрагента, "Код", Код);

    Если ПерезаписыватьНаименование Или Не ЗначениеЗаполнено(ПолучитьСвойствоОбъекта(ОбъектКонтрагента, "Наименование")) Тогда
        УстановитьСвойствоЕслиЕсть(ОбъектКонтрагента, "Наименование", ПолучитьСтроку(ДанныеКонтрагента, "Наименование"));
        УстановитьСвойствоЕслиЕсть(ОбъектКонтрагента, "ПолноеНаименование", ПолучитьСтроку(ДанныеКонтрагента, "ПолноеНаименование"));
        УстановитьСвойствоЕслиЕсть(ОбъектКонтрагента, "НаименованиеПолное", ПолучитьСтроку(ДанныеКонтрагента, "ПолноеНаименование"));
    КонецЕсли;

    Если Не ЭтоГруппа Тогда
        УстановитьСвойствоЕслиЕсть(ОбъектКонтрагента, "ЮридическоеФизическоеЛицо", ОпределитьЮридическоеФизическоеЛицо(ПолучитьСтроку(ДанныеКонтрагента, "ЮрФизЛицо")));
        УстановитьСвойствоЕслиЕсть(ОбъектКонтрагента, "ОбособленноеПодразделение", Ложь);
        УстановитьСвойствоЕслиЕсть(ОбъектКонтрагента, "ИНН", ПолучитьСтроку(ДанныеКонтрагента, "ИНН"));
        УстановитьСвойствоЕслиЕсть(ОбъектКонтрагента, "КПП", ПолучитьСтроку(ДанныеКонтрагента, "КПП"));
        УстановитьГоловногоКонтрагентаПоУмолчанию(ОбъектКонтрагента);
    КонецЕсли;

    УстановитьСвойствоЕслиЕсть(ОбъектКонтрагента, "Комментарий", ПолучитьСтроку(ДанныеКонтрагента, "Комментарий"));

    Попытка
        ОбъектКонтрагента.Записать();
    Исключение
        Если Не ЭтоГруппа Тогда
            УстановитьГоловногоКонтрагентаПоУмолчанию(ОбъектКонтрагента, Истина);
            ОбъектКонтрагента.Записать();
        Иначе
            ВызватьИсключение;
        КонецЕсли;
    КонецПопытки;

    Если Не ЭтоГруппа Тогда
        ДозаполнитьГоловногоКонтрагентаПослеЗаписи(ОбъектКонтрагента.Ссылка);
    КонецЕсли;

    ЗагруженныеКонтрагенты.Вставить(Код, ОбъектКонтрагента.Ссылка);

    ДобавитьВПротокол(Протокол, "Загружен контрагент: " + ПолучитьСтроку(ДанныеКонтрагента, "Наименование"));
    Возврат ОбъектКонтрагента.Ссылка;

КонецФункции

Функция ИмпортироватьНоменклатуру(ДанныеНоменклатуры, ИндексНоменклатуры, ЗагруженнаяНоменклатура, ВидНоменклатурыПоУмолчанию, ПерезаписыватьНаименование, Протокол)

    Код = ПолучитьСтроку(ДанныеНоменклатуры, "Код");
    Если ПустаяСтрока(Код) Тогда
        Возврат Неопределено;
    КонецЕсли;

    Если СоответствиеСодержитКлюч(ЗагруженнаяНоменклатура, Код) Тогда
        Возврат ЗагруженнаяНоменклатура.Получить(Код);
    КонецЕсли;

    Родитель = ПолучитьСсылкуРодителяНоменклатуры(ДанныеНоменклатуры, ИндексНоменклатуры, ЗагруженнаяНоменклатура, ВидНоменклатурыПоУмолчанию, ПерезаписыватьНаименование, Протокол);
    ЭтоГруппа = ЭтоИстина(ПолучитьСтроку(ДанныеНоменклатуры, "ЭтоГруппа"));
    ЭтоУслуга = ЭтоИстина(ПолучитьСтроку(ДанныеНоменклатуры, "Услуга"));

    СсылкаНоменклатуры = НайтиНоменклатуру(ДанныеНоменклатуры, ЭтоГруппа);
    Если ЗначениеЗаполнено(СсылкаНоменклатуры) Тогда
        ОбъектНоменклатуры = СсылкаНоменклатуры.ПолучитьОбъект();
    ИначеЕсли ЭтоГруппа Тогда
        ОбъектНоменклатуры = Справочники.Номенклатура.СоздатьГруппу();
    Иначе
        ОбъектНоменклатуры = Справочники.Номенклатура.СоздатьЭлемент();
    КонецЕсли;

    УстановитьСвойствоЕслиЕсть(ОбъектНоменклатуры, "Родитель", Родитель);
    УстановитьСвойствоЕслиЕсть(ОбъектНоменклатуры, "Код", Код);
    УстановитьСвойствоЕслиЕсть(ОбъектНоменклатуры, "ВидНоменклатуры", НайтиВидНоменклатуры(ПолучитьСтроку(ДанныеНоменклатуры, "ВидНоменклатуры"), ВидНоменклатурыПоУмолчанию, ЭтоУслуга));

    Если ПерезаписыватьНаименование Или Не ЗначениеЗаполнено(ПолучитьСвойствоОбъекта(ОбъектНоменклатуры, "Наименование")) Тогда
        УстановитьСвойствоЕслиЕсть(ОбъектНоменклатуры, "Наименование", ПолучитьСтроку(ДанныеНоменклатуры, "Наименование"));
        УстановитьСвойствоЕслиЕсть(ОбъектНоменклатуры, "ПолноеНаименование", ПолучитьСтроку(ДанныеНоменклатуры, "ПолноеНаименование"));
        УстановитьСвойствоЕслиЕсть(ОбъектНоменклатуры, "НаименованиеПолное", ПолучитьСтроку(ДанныеНоменклатуры, "ПолноеНаименование"));
    КонецЕсли;

    Если Не ЭтоГруппа Тогда
        УстановитьСвойствоЕслиЕсть(ОбъектНоменклатуры, "Артикул", ПолучитьСтроку(ДанныеНоменклатуры, "Артикул"));
        УстановитьСвойствоЕслиЕсть(ОбъектНоменклатуры, "Комментарий", ПолучитьСтроку(ДанныеНоменклатуры, "Комментарий"));
        УстановитьСвойствоЕслиЕсть(ОбъектНоменклатуры, "СтавкаНДС", ОпределитьСтавкуНДС(ПолучитьСтроку(ДанныеНоменклатуры, "СтавкаНДС")));
        УстановитьСвойствоЕслиЕсть(ОбъектНоменклатуры, "Услуга", ЭтоУслуга);
        УстановитьСвойствоЕслиЕсть(ОбъектНоменклатуры, "ЕдиницаИзмерения", НайтиЕдиницуИзмерения(
            ПолучитьСтроку(ДанныеНоменклатуры, "ЕдиницаИзмеренияКод"),
            ПолучитьСтроку(ДанныеНоменклатуры, "ЕдиницаИзмерения"),
            ПолучитьСтроку(ДанныеНоменклатуры, "ЕдиницаИзмеренияПолноеНаименование")));
    КонецЕсли;

    ОбъектНоменклатуры.Записать();
    ЗагруженнаяНоменклатура.Вставить(Код, ОбъектНоменклатуры.Ссылка);

    ДобавитьВПротокол(Протокол, "Загружена номенклатура: " + ПолучитьСтроку(ДанныеНоменклатуры, "Наименование"));
    Возврат ОбъектНоменклатуры.Ссылка;

КонецФункции

Функция ИмпортироватьАдресКонтрагента(ДанныеАдреса, ЗагруженныеКонтрагенты, Протокол)

    КодКонтрагента = ПолучитьСтроку(ДанныеАдреса, "КодКонтрагента");
    Если ПустаяСтрока(КодКонтрагента) Тогда
        Возврат Ложь;
    КонецЕсли;

    СсылкаКонтрагента = ПолучитьСсылкуКонтрагентаПоКоду(КодКонтрагента, ЗагруженныеКонтрагенты);
    Если Не ЗначениеЗаполнено(СсылкаКонтрагента) Тогда
        ДобавитьВПротокол(Протокол, "Не найден контрагент для загрузки адреса, код: " + КодКонтрагента);
        Возврат Ложь;
    КонецЕсли;

    Представление = ПодготовитьПредставлениеКонтактнойИнформации(ДанныеАдреса);
    Если ПустаяСтрока(Представление) Тогда
        Возврат Ложь;
    КонецЕсли;

    ОбъектКонтрагента = СсылкаКонтрагента.ПолучитьОбъект();
    ТипКонтактнойИнформации = ОпределитьТипКонтактнойИнформации(ПолучитьСтроку(ДанныеАдреса, "Тип"));
    ВидКонтактнойИнформации = НайтиВидКонтактнойИнформации(ПолучитьСтроку(ДанныеАдреса, "Вид"), ТипКонтактнойИнформации);

    СтрокаКонтактнойИнформации = НайтиСтрокуКонтактнойИнформации(
        ОбъектКонтрагента.КонтактнаяИнформация,
        ТипКонтактнойИнформации,
        ВидКонтактнойИнформации,
        Представление);

    Если СтрокаКонтактнойИнформации = Неопределено Тогда
        СтрокаКонтактнойИнформации = ОбъектКонтрагента.КонтактнаяИнформация.Добавить();
    КонецЕсли;

    УстановитьСвойствоЕслиЕсть(СтрокаКонтактнойИнформации, "Тип", ТипКонтактнойИнформации);
    УстановитьСвойствоЕслиЕсть(СтрокаКонтактнойИнформации, "Вид", ВидКонтактнойИнформации);
    УстановитьСвойствоЕслиЕсть(СтрокаКонтактнойИнформации, "ВидДляСписка", ВидКонтактнойИнформации);
    УстановитьСвойствоЕслиЕсть(СтрокаКонтактнойИнформации, "Представление", Представление);
    УстановитьСвойствоЕслиЕсть(СтрокаКонтактнойИнформации, "Значение", Представление);
    УстановитьСвойствоЕслиЕсть(СтрокаКонтактнойИнформации, "ЗначенияПолей", Представление);
    ЗаполнитьПоляАдресаКонтрагента(СтрокаКонтактнойИнформации, ДанныеАдреса);

    УстановитьГоловногоКонтрагентаПоУмолчанию(ОбъектКонтрагента);
    Попытка
        ОбъектКонтрагента.Записать();
    Исключение
        УстановитьГоловногоКонтрагентаПоУмолчанию(ОбъектКонтрагента, Истина);
        ОбъектКонтрагента.Записать();
    КонецПопытки;

    ДобавитьВПротокол(Протокол, "Загружен адрес контрагента: " + Представление);
    Возврат Истина;

КонецФункции

Функция ИмпортироватьБанковскийСчетКонтрагента(ДанныеБанковскогоСчета, ЗагруженныеКонтрагенты, Протокол)

    КодКонтрагента = ПолучитьСтроку(ДанныеБанковскогоСчета, "КодКонтрагента");
    НомерСчета = ПолучитьСтроку(ДанныеБанковскогоСчета, "НомерСчета");

    Если ПустаяСтрока(КодКонтрагента) Или ПустаяСтрока(НомерСчета) Тогда
        Возврат Ложь;
    КонецЕсли;

    СсылкаКонтрагента = ПолучитьСсылкуКонтрагентаПоКоду(КодКонтрагента, ЗагруженныеКонтрагенты);
    Если Не ЗначениеЗаполнено(СсылкаКонтрагента) Тогда
        ДобавитьВПротокол(Протокол, "Не найден контрагент для загрузки банковского счета, код: " + КодКонтрагента);
        Возврат Ложь;
    КонецЕсли;

    СсылкаБанка = НайтиИлиСоздатьБанк(
        ПолучитьСтроку(ДанныеБанковскогоСчета, "БанкБИК"),
        ПолучитьСтроку(ДанныеБанковскогоСчета, "БанкНаименование"),
        ПолучитьСтроку(ДанныеБанковскогоСчета, "БанкКоррСчет"),
        ПолучитьСтроку(ДанныеБанковскогоСчета, "БанкГород"),
        ПолучитьСтроку(ДанныеБанковскогоСчета, "БанкАдрес"));
    Если Не ЗначениеЗаполнено(СсылкаБанка) Тогда
        ДобавитьВПротокол(Протокол, "Не удалось подготовить банк для счета " + НомерСчета);
        Возврат Ложь;
    КонецЕсли;

    СсылкаВалюты = НайтиВалюту(
        ПолучитьСтроку(ДанныеБанковскогоСчета, "ВалютаКод"),
        ПолучитьСтроку(ДанныеБанковскогоСчета, "Валюта"),
        ПолучитьСтроку(ДанныеБанковскогоСчета, "ВалютаПолноеНаименование"));
    Если Не ЗначениеЗаполнено(СсылкаВалюты) Тогда
        СсылкаВалюты = НайтиВалютуПоУмолчанию();
    КонецЕсли;

    СсылкаБанковскогоСчета = НайтиБанковскийСчетКонтрагента(СсылкаКонтрагента, НомерСчета);
    Если ЗначениеЗаполнено(СсылкаБанковскогоСчета) Тогда
        ОбъектБанковскогоСчета = СсылкаБанковскогоСчета.ПолучитьОбъект();
    Иначе
        ОбъектБанковскогоСчета = Справочники.БанковскиеСчета.СоздатьЭлемент();
    КонецЕсли;

    УстановитьСвойствоЕслиЕсть(ОбъектБанковскогоСчета, "Владелец", СсылкаКонтрагента);
    УстановитьСвойствоЕслиЕсть(ОбъектБанковскогоСчета, "Наименование", ПолучитьПервуюНепустуюСтроку(
        ПолучитьСтроку(ДанныеБанковскогоСчета, "Наименование"),
        НомерСчета));
    УстановитьСвойствоЕслиЕсть(ОбъектБанковскогоСчета, "НомерСчета", НомерСчета);
    УстановитьСвойствоЕслиЕсть(ОбъектБанковскогоСчета, "Банк", СсылкаБанка);
    УстановитьСвойствоЕслиЕсть(ОбъектБанковскогоСчета, "БанкДляРасчетов", СсылкаБанка);
    УстановитьСвойствоЕслиЕсть(ОбъектБанковскогоСчета, "Валютный", ЭтоИстина(ПолучитьСтроку(ДанныеБанковскогоСчета, "Валютный")));
    УстановитьСвойствоЕслиЕсть(ОбъектБанковскогоСчета, "ВалютаДенежныхСредств", СсылкаВалюты);
    УстановитьСвойствоЕслиЕсть(ОбъектБанковскогоСчета, "ДатаОткрытия", ПрочитатьДатуИзСтроки(ПолучитьСтроку(ДанныеБанковскогоСчета, "ДатаОткрытия")));
    УстановитьСвойствоЕслиЕсть(ОбъектБанковскогоСчета, "ДатаЗакрытия", ПрочитатьДатуИзСтроки(ПолучитьСтроку(ДанныеБанковскогоСчета, "ДатаЗакрытия")));
    ОбъектБанковскогоСчета.Записать();

    УстановитьОсновнойБанковскийСчетКонтрагента(СсылкаКонтрагента, ОбъектБанковскогоСчета.Ссылка);

    ДобавитьВПротокол(Протокол, "Загружен банковский счет контрагента: " + НомерСчета);
    Возврат Истина;

КонецФункции

Функция ИмпортироватьШтрихкодНоменклатуры(ДанныеШтрихкода, ЗагруженнаяНоменклатура, Протокол)

    КодНоменклатуры = ПолучитьСтроку(ДанныеШтрихкода, "КодНоменклатуры");
    Штрихкод = ПолучитьСтроку(ДанныеШтрихкода, "Штрихкод");

    Если ПустаяСтрока(КодНоменклатуры) Или ПустаяСтрока(Штрихкод) Тогда
        Возврат Ложь;
    КонецЕсли;

    СсылкаНоменклатуры = ПолучитьСсылкуНоменклатурыПоКоду(КодНоменклатуры, ЗагруженнаяНоменклатура);
    Если Не ЗначениеЗаполнено(СсылкаНоменклатуры) Тогда
        ДобавитьВПротокол(Протокол, "Не найдена номенклатура для загрузки штрихкода, код: " + КодНоменклатуры);
        Возврат Ложь;
    КонецЕсли;

    СуществующаяНоменклатура = НайтиНоменклатуруПоШтрихкоду(Штрихкод);
    Если ЗначениеЗаполнено(СуществующаяНоменклатура) Тогда
        Если СуществующаяНоменклатура = СсылкаНоменклатуры Тогда
            Возврат Ложь;
        КонецЕсли;

        ДобавитьВПротокол(Протокол, "Штрихкод уже существует в БП и привязан к другой номенклатуре: " + Штрихкод);
        Возврат Ложь;
    КонецЕсли;

    НаборЗаписей = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей();
    НоваяЗапись = НаборЗаписей.Добавить();
    НоваяЗапись.Штрихкод = Штрихкод;
    НоваяЗапись.Номенклатура = СсылкаНоменклатуры;
    НаборЗаписей.Записать();

    ДобавитьВПротокол(Протокол, "Загружен штрихкод номенклатуры: " + Штрихкод);
    Возврат Истина;

КонецФункции

Функция ПолучитьСсылкуРодителяКонтрагента(ДанныеКонтрагента, ИндексКонтрагентов, ЗагруженныеКонтрагенты, ПерезаписыватьНаименование, Протокол)

    КодРодителя = ПолучитьСтроку(ДанныеКонтрагента, "КодРодителя");
    Если ПустаяСтрока(КодРодителя) Тогда
        Возврат Неопределено;
    КонецЕсли;

    Если СоответствиеСодержитКлюч(ЗагруженныеКонтрагенты, КодРодителя) Тогда
        Возврат ЗагруженныеКонтрагенты.Получить(КодРодителя);
    КонецЕсли;

    Если СоответствиеСодержитКлюч(ИндексКонтрагентов, КодРодителя) Тогда
        Возврат ИмпортироватьКонтрагента(ИндексКонтрагентов.Получить(КодРодителя), ИндексКонтрагентов, ЗагруженныеКонтрагенты, ПерезаписыватьНаименование, Протокол);
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

Функция ПолучитьСсылкуРодителяНоменклатуры(ДанныеНоменклатуры, ИндексНоменклатуры, ЗагруженнаяНоменклатура, ВидНоменклатурыПоУмолчанию, ПерезаписыватьНаименование, Протокол)

    КодРодителя = ПолучитьСтроку(ДанныеНоменклатуры, "КодРодителя");
    Если ПустаяСтрока(КодРодителя) Тогда
        Возврат Неопределено;
    КонецЕсли;

    Если СоответствиеСодержитКлюч(ЗагруженнаяНоменклатура, КодРодителя) Тогда
        Возврат ЗагруженнаяНоменклатура.Получить(КодРодителя);
    КонецЕсли;

    Если СоответствиеСодержитКлюч(ИндексНоменклатуры, КодРодителя) Тогда
        Возврат ИмпортироватьНоменклатуру(ИндексНоменклатуры.Получить(КодРодителя), ИндексНоменклатуры, ЗагруженнаяНоменклатура, ВидНоменклатурыПоУмолчанию, ПерезаписыватьНаименование, Протокол);
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

Функция НайтиКонтрагента(ДанныеКонтрагента, ЭтоГруппа)

    Если ЭтоГруппа Тогда
        Ссылка = Справочники.Контрагенты.НайтиПоКоду(ПолучитьСтроку(ДанныеКонтрагента, "Код"));
        Если ЭтоИскомыйВидСсылки(Ссылка, Истина) Тогда
            Возврат Ссылка;
        КонецЕсли;

        Ссылка = Справочники.Контрагенты.НайтиПоНаименованию(ПолучитьСтроку(ДанныеКонтрагента, "Наименование"));
        Если ЭтоИскомыйВидСсылки(Ссылка, Истина) Тогда
            Возврат Ссылка;
        КонецЕсли;

        Возврат Неопределено;
    КонецЕсли;

    ИНН = ПолучитьСтроку(ДанныеКонтрагента, "ИНН");
    Если Не ПустаяСтрока(ИНН) Тогда
        Ссылка = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", ИНН);
        Если ЭтоИскомыйВидСсылки(Ссылка, Ложь) Тогда
            Возврат Ссылка;
        КонецЕсли;
    КонецЕсли;

    Ссылка = Справочники.Контрагенты.НайтиПоКоду(ПолучитьСтроку(ДанныеКонтрагента, "Код"));
    Если ЭтоИскомыйВидСсылки(Ссылка, Ложь) Тогда
        Возврат Ссылка;
    КонецЕсли;

    Ссылка = Справочники.Контрагенты.НайтиПоНаименованию(ПолучитьСтроку(ДанныеКонтрагента, "Наименование"));
    Если ЭтоИскомыйВидСсылки(Ссылка, Ложь) Тогда
        Возврат Ссылка;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

Функция НайтиНоменклатуру(ДанныеНоменклатуры, ЭтоГруппа)

    Ссылка = Справочники.Номенклатура.НайтиПоКоду(ПолучитьСтроку(ДанныеНоменклатуры, "Код"));
    Если ЭтоИскомыйВидСсылки(Ссылка, ЭтоГруппа) Тогда
        Возврат Ссылка;
    КонецЕсли;

    Если Не ЭтоГруппа Тогда
        Артикул = ПолучитьСтроку(ДанныеНоменклатуры, "Артикул");
        Если Не ПустаяСтрока(Артикул) Тогда
            Ссылка = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", Артикул);
            Если ЭтоИскомыйВидСсылки(Ссылка, Ложь) Тогда
                Возврат Ссылка;
            КонецЕсли;
        КонецЕсли;
    КонецЕсли;

    Ссылка = Справочники.Номенклатура.НайтиПоНаименованию(ПолучитьСтроку(ДанныеНоменклатуры, "Наименование"));
    Если ЭтоИскомыйВидСсылки(Ссылка, ЭтоГруппа) Тогда
        Возврат Ссылка;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

Функция ПолучитьСсылкуКонтрагентаПоКоду(КодКонтрагента, ЗагруженныеКонтрагенты)

    Если СоответствиеСодержитКлюч(ЗагруженныеКонтрагенты, КодКонтрагента) Тогда
