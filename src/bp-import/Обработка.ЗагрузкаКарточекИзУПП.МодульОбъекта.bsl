Функция ПрочитатьДатуИзСтроки(СтрокаДаты)

    ТекстДаты = СокрЛП(СтрокаДаты);
    Если ПустаяСтрока(ТекстДаты) Или СтрДлина(ТекстДаты) < 10 Тогда
        Возврат Неопределено;
    КонецЕсли;

    Попытка
        День = Число(Лев(ТекстДаты, 2));
        Месяц = Число(Сред(ТекстДаты, 4, 2));
        Год = Число(Сред(ТекстДаты, 7, 4));
        Час = ?(СтрДлина(ТекстДаты) >= 13, Число(Сред(ТекстДаты, 12, 2)), 0);
        Минута = ?(СтрДлина(ТекстДаты) >= 16, Число(Сред(ТекстДаты, 15, 2)), 0);
        Секунда = ?(СтрДлина(ТекстДаты) >= 19, Число(Сред(ТекстДаты, 18, 2)), 0);
        Возврат Дата(Год, Месяц, День, Час, Минута, Секунда);
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

