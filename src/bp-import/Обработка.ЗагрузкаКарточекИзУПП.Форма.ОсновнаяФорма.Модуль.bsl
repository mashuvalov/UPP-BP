&НаКлиенте
Процедура ПриОткрытии()

    ПодключитьОбработчикОжидания("ЗапуститьЗагрузкуПослеОткрытия", 0.1, Истина);

КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьНажатие(Команда)

    ИмяФайла = ВыбратьФайлЗагрузки();
    Если ПустаяСтрока(ИмяФайла) Тогда
        Возврат;
    КонецЕсли;

    Попытка
        Результат = ВыполнитьЗагрузкуНаСервере(ИмяФайла);
    Исключение
        Сообщить(ОписаниеОшибки());
        Возврат;
    КонецПопытки;

    Сообщить("Загрузка завершена. Контрагентов: "
        + Строка(Результат.КоличествоКонтрагентов)
        + ", адресов: "
        + Строка(Результат.КоличествоАдресовКонтрагентов)
        + ", счетов: "
        + Строка(Результат.КоличествоБанковскихСчетов)
        + ", номенклатуры: "
        + Строка(Результат.КоличествоНоменклатуры)
        + ", штрихкодов: "
        + Строка(Результат.КоличествоШтрихкодов));

КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьЗагрузкуПослеОткрытия()

    ЗагрузитьНажатие(Неопределено);

КонецПроцедуры

&НаСервере
Функция ВыполнитьЗагрузкуНаСервере(ИмяФайла)

    ПараметрыЗагрузки = Новый Структура;
    ПараметрыЗагрузки.Вставить("ИмяФайла", ИмяФайла);
    ПараметрыЗагрузки.Вставить("ВидНоменклатурыПоУмолчанию", "Товар");
    ПараметрыЗагрузки.Вставить("ПерезаписыватьНаименование", Истина);

    Протокол = Новый Массив;
    ОбъектОбработки = РеквизитФормыВЗначение("Объект");
    Результат = ОбъектОбработки.ВыполнитьЗагрузку(ПараметрыЗагрузки, Протокол);

    Для Каждого ТекстСообщения Из Протокол Цикл
        Сообщить(ТекстСообщения);
    КонецЦикла;

    Возврат Результат;

КонецФункции

&НаКлиенте
Функция ВыбратьФайлЗагрузки()

    Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
    Диалог.Фильтр = "XML-файлы (*.xml)|*.xml";
    Диалог.Заголовок = "Выберите файл обмена";

    Если Диалог.Выбрать() Тогда
        Возврат Диалог.ПолноеИмяФайла;
    КонецЕсли;

    Возврат "";

КонецФункции
